{
  "name": "thea-ehr",
  "version": "2.0.0",
  "private": true,
  "description": "Thea Electronic Health Records System",
  "keywords": [
    "thea",
    "ehr",
    "healthcare",
    "medical"
  ],
  "homepage": "https://thea.health",
  "author": "Thea Technologies",
  "license": "Proprietary",
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev --hostname 0.0.0.0 --port 3000",
    "dev:no-reload": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:webpack": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' next build",
    "rebuild": "yarn clean && yarn build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "next lint --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:opd": "playwright test __tests__/e2e/opd-journey.spec.ts",
    "test:e2e:er": "playwright test __tests__/e2e/er-journey.spec.ts",
    "test:e2e:ipd": "playwright test __tests__/e2e/ipd-journey.spec.ts",
    "test:e2e:or": "playwright test __tests__/e2e/or-journey.spec.ts",
    "test:e2e:nav": "playwright test __tests__/e2e/navigation.spec.ts",
    "test:e2e:portal": "playwright test __tests__/e2e/portal.spec.ts",
    "test:e2e:all": "playwright test __tests__/e2e/",
    "test:unit": "vitest run --exclude '__tests__/integration/**'",
    "test:integration": "dotenv -e .env.local -- vitest run --config vitest.integration.config.ts",
    "test:performance": "dotenv -e .env.local -- vitest run --config vitest.performance.config.ts",
    "test:perf:report": "dotenv -e .env.local -- tsx __tests__/performance/report-generator.ts",
    "test:security": "dotenv -e .env.local -- vitest run --config vitest.security.config.ts",
    "test:security:injection": "dotenv -e .env.local -- vitest run --config vitest.security.config.ts __tests__/security/injection.test.ts",
    "test:security:auth": "dotenv -e .env.local -- vitest run --config vitest.security.config.ts __tests__/security/authentication.test.ts",
    "test:quality": "tsx scripts/run-quality-gate.ts",
    "routes:ui": "tsx scripts/generate-ui-routes.ts",
    "test:ui-crawl": "playwright test __tests__/e2e/ui-crawl.spec.ts",
    "verify:ui": "yarn routes:ui && yarn test:ui-crawl",
    "load:smoke": "k6 run load-tests/k6-smoke.js",
    "load:test": "k6 run load-tests/k6-load.js",
    "load:stress": "k6 run load-tests/k6-stress.js",
    "sim": "npx tsx simulator/cli.ts",
    "sim:seed": "npx tsx simulator/seed.ts",
    "sim:smoke": "npx tsx simulator/cli.ts --profile smoke",
    "sim:stress": "npx tsx simulator/cli.ts --profile stress",
    "codemod:auth": "tsx scripts/codemod-apply-auth-wrapper.ts",
    "codemod:improved": "tsx scripts/codemod-improved.ts",
    "codemod:v2": "tsx scripts/codemod-improved-v2.ts",
    "seed:test": "dotenv -e .env.local -- tsx scripts/seed-test-data.ts",
    "seed:er-demo": "dotenv -e .env.local -- tsx scripts/seed/seed_er_demo.ts",
    "seed:demo": "dotenv -e .env.local -- tsx scripts/seed/seed-full-demo.ts",
    "seed:demo:wipe": "dotenv -e .env.local -- tsx scripts/seed/seed-full-demo.ts --wipe",
    "bootstrap:owner": "dotenv -e .env.local -- tsx scripts/bootstrapOwner.ts",
    "migrate:assign-users": "tsx scripts/migrations/005_assign_users_to_tenants.ts",
    "migrate:er-init": "tsx scripts/migrations/020_er_init.ts",
    "seed:test-tenant": "dotenv -e .env.local -- tsx scripts/seed/seed_test_tenant.ts",
    "verify:tenant-isolation": "dotenv -e .env.local -- tsx scripts/verify_tenant_isolation.ts",
    "verify:db-isolation": "node scripts/verify-tenant-isolation.cjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:validate": "prisma validate",
    "db:seed": "prisma db seed",
    "db:status": "prisma migrate status",
    "db:migrate:prod": "npx tsx scripts/migrate-production.ts",
    "seed:icd10": "dotenv -e .env.local -- tsx scripts/seed-icd10.ts"
  },
  "engines": {
    "node": "20.x",
    "yarn": ">=1.22.0"
  },
