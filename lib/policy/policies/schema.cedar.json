{
  "Thea": {
    "entityTypes": {
      "User": {
        "shape": {
          "type": "Record",
          "attributes": {
            "tenantId":   { "type": "String", "required": true },
            "hospitalId": { "type": "String", "required": false },
            "role":       { "type": "String", "required": true }
          }
        }
      },
      "Tenant": {
        "shape": {
          "type": "Record",
          "attributes": {}
        }
      },
      "Hospital": {
        "shape": {
          "type": "Record",
          "attributes": {
            "tenantId": { "type": "String", "required": true }
          }
        }
      },
      "Resource": {
        "shape": {
          "type": "Record",
          "attributes": {
            "tenantId": { "type": "String", "required": true }
          }
        }
      },
      "HospitalResource": {
        "shape": {
          "type": "Record",
          "attributes": {
            "tenantId":   { "type": "String", "required": true },
            "hospitalId": { "type": "String", "required": false }
          }
        }
      },
      "ClinicalEncounter": {
        "shape": {
          "type": "Record",
          "attributes": {
            "tenantId":   { "type": "String", "required": true },
            "hospitalId": { "type": "String", "required": false },
            "status":     { "type": "String", "required": false },
            "patientId":  { "type": "String", "required": false }
          }
        }
      },
      "CvisionEmployee": {
        "shape": {
          "type": "Record",
          "attributes": {
            "tenantId":       { "type": "String", "required": true },
            "organizationId": { "type": "String", "required": false },
            "status":         { "type": "String", "required": false }
          }
        }
      },
      "ImdadPurchaseOrder": {
        "shape": {
          "type": "Record",
          "attributes": {
            "tenantId":       { "type": "String", "required": true },
            "organizationId": { "type": "String", "required": false },
            "status":         { "type": "String", "required": false },
            "amount":         { "type": "Long",   "required": false }
          }
        }
      },
      "SamPolicy": {
        "shape": {
          "type": "Record",
          "attributes": {
            "tenantId": { "type": "String", "required": true },
            "status":   { "type": "String", "required": false },
            "scope":    { "type": "String", "required": false }
          }
        }
      }
    },
    "actions": {
      "Read": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Resource", "HospitalResource"]
        }
      },
      "Write": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Resource", "HospitalResource"]
        }
      },
      "Delete": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["Resource", "HospitalResource"]
        }
      },
      "View": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["ClinicalEncounter", "CvisionEmployee", "ImdadPurchaseOrder", "SamPolicy"]
        }
      },
      "Create": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["ClinicalEncounter", "CvisionEmployee", "ImdadPurchaseOrder", "SamPolicy"]
        }
      },
      "Update": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["ClinicalEncounter", "CvisionEmployee", "ImdadPurchaseOrder", "SamPolicy"]
        }
      },
      "Approve": {
        "appliesTo": {
          "principalTypes": ["User"],
          "resourceTypes":  ["ClinicalEncounter", "CvisionEmployee", "ImdadPurchaseOrder", "SamPolicy"]
        }
      }
    }
  }
}
