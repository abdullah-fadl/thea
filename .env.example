# ==============================================================================
# Thea EHR — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in the required values.
# انسخ هذا الملف إلى .env.local واملأ القيم المطلوبة.
# ==============================================================================

# ==============================================================================
# 🗄️ DATABASE — قاعدة البيانات
# ==============================================================================

# [Required] PostgreSQL connection string (Supabase / self-hosted)
# رابط اتصال PostgreSQL — مطلوب
DATABASE_URL=postgresql://postgres:password@localhost:5432/thea?schema=public

# [Required] Direct connection URL (bypasses connection pooler for migrations)
# رابط اتصال مباشر — مطلوب للترحيلات
DIRECT_URL=postgresql://postgres:password@localhost:5432/thea?schema=public

# [Optional] Migration-specific URL (defaults to DIRECT_URL)
# رابط خاص بالترحيلات — اختياري
# MIGRATION_URL=

# ==============================================================================
# 🔐 AUTH & SECURITY — المصادقة والأمان
# ==============================================================================

# [Required] JWT secret key — generate with: openssl rand -base64 32
# مفتاح سري لتوقيع JWT — مطلوب
JWT_SECRET=REPLACE_ME_WITH_SECURE_SECRET

# [Optional] Previous JWT secret for key rotation
# مفتاح JWT السابق — للتدوير
# JWT_SECRET_PREVIOUS=

# [Optional] CSRF protection secret
# مفتاح حماية CSRF — اختياري
# CSRF_SECRET=

# [Optional] Cookie domain for multi-subdomain auth
# نطاق الكوكيز — اختياري
# COOKIE_DOMAIN=.thea.com.sa

# [Optional] Field-level encryption key (AES-256)
# مفتاح التشفير على مستوى الحقول — اختياري
# FIELD_ENCRYPTION_KEY=

# [Optional] Account lockout settings
# إعدادات قفل الحساب — اختياري
# ACCOUNT_LOCKOUT_MAX_FAILED=5
# ACCOUNT_LOCKOUT_DURATION_MS=900000

# [Optional] MFA TOTP issuer name
# اسم مُصدر TOTP — اختياري
# MFA_TOTP_ISSUER=Thea EHR

# ==============================================================================
# 🔑 SESSION — الجلسات
# ==============================================================================

# [Optional] Session idle timeout in minutes (default: 30)
# مهلة خمول الجلسة بالدقائق — اختياري
# SESSION_IDLE_MINUTES=30

# [Optional] Session idle timeout in ms (alternative)
# SESSION_IDLE_TIMEOUT_MS=1800000

# [Optional] Maximum absolute session age in ms
# أقصى عمر مطلق للجلسة بالمللي ثانية — اختياري
# SESSION_ABSOLUTE_MAX_AGE_MS=86400000

# [Optional] Portal session duration in days
# مدة جلسة البوابة بالأيام — اختياري
# PORTAL_SESSION_DAYS=30

# [Optional] Portal idle timeout in minutes
# مهلة خمول البوابة بالدقائق — اختياري
# PORTAL_IDLE_MINUTES=60

# ==============================================================================
# 🌐 APP — إعدادات التطبيق
# ==============================================================================

# [Optional] Public base URL
# رابط التطبيق العام — اختياري
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# [Optional] Port (default: 3000)
# PORT=3000

# [Optional] Node environment (set automatically by Next.js)
# NODE_ENV=development

# [Optional] Log level: debug | info | warn | error
# مستوى السجلات — اختياري
LOG_LEVEL=debug

# [Optional] Maximum JSON body size in KB (default: 100)
# أقصى حجم JSON بالكيلوبايت — اختياري
# MAX_JSON_KB=100

# [Optional] Enable Content Security Policy
# تفعيل سياسة أمان المحتوى — اختياري
# SECURITY_CSP=0

# [Optional] HSTS max age in seconds
# HSTS_MAX_AGE=31536000

# [Optional] CSP report URI
# CSP_REPORT_URI=

# [Optional] Enable hardened rate limits
# تفعيل حدود معدل مشددة — اختياري
# HARDEN_LIMITS=0

# ==============================================================================
# 👑 OWNER — إعدادات المالك
# ==============================================================================

# [Required] Owner account email
# بريد حساب المالك — مطلوب
THEA_OWNER_EMAIL=thea@thea.com.sa

# [Required] Owner account password (used in bootstrap scripts)
# كلمة مرور حساب المالك — مطلوب لسكربتات البداية
THEA_OWNER_PASSWORD=REPLACE_ME

# [Optional] Test mode — bypasses some checks (NEVER use in production)
# وضع الاختبار — لا تستخدمه في الإنتاج أبداً
# THEA_TEST_MODE=false

# ==============================================================================
# 🔄 REDIS — التخزين المؤقت
# ==============================================================================

# [Optional] Redis connection URL (for rate limiting, caching, sessions)
# رابط Redis — اختياري
# REDIS_URL=redis://localhost:6379

# ==============================================================================
# 🏥 CORS — مشاركة الموارد عبر الأصول
# ==============================================================================

# [Optional] Allowed origins — comma-separated (default: '*')
# الأصول المسموح بها — اختياري
CORS_ORIGINS=*

# [Optional] Alternative CORS config key
# CORS_ALLOWED_ORIGINS=*

# ==============================================================================
# ⏱️ RATE LIMITING — حدود المعدل
# ==============================================================================

# [Optional] API rate limit: max requests per window
# RATE_LIMIT_API_MAX=100
# RATE_LIMIT_API_WINDOW_MS=60000

# [Optional] Login rate limit
# RATE_LIMIT_LOGIN_MAX=10
# RATE_LIMIT_LOGIN_WINDOW_MS=900000

# ==============================================================================
# 🆔 IDENTITY GATEWAY — بوابة الهوية
# ==============================================================================

# [Optional] Provider: 'mock' or 'nic'
# مزود الهوية — اختياري
IDENTITY_PROVIDER=mock

# [Optional] Require date of birth for lookup
IDENTITY_REQUIRE_DOB_FOR_LOOKUP=1

# [Optional] Allow ER lookup without DOB
IDENTITY_ER_ALLOW_NO_DOB=1

# [Optional] Hash pepper for identityValueHash
# IDENTITY_HASH_PEPPER=

# [Optional] Encrypted raw storage for identityValue
# IDENTITY_STORE_RAW=0
# IDENTITY_STORE_RAW_KEY=

# [Optional] Dedupe and rate limit controls
# IDENTITY_DEDUPE_TTL_MIN=5
# IDENTITY_RL_CAPACITY=20
# IDENTITY_RL_REFILL_PER_MIN=20

# ==============================================================================
# 🤖 AI & TRANSLATION — الذكاء الاصطناعي والترجمة
# ==============================================================================

# [Optional] Translation API key (OpenAI or compatible)
# مفتاح API للترجمة — اختياري
# TRANSLATION_API_KEY=

# ==============================================================================
# 👁️ CVISION — منصة CVision للموارد البشرية
# ==============================================================================

# --- CVision Auth (REQUIRED) ---
# مصادقة CVision — مطلوب

# [Required] JWT signing secret for CVision access tokens
# Must be stable across restarts (changing this invalidates all active sessions)
# مفتاح توقيع JWT لرموز الوصول — يجب أن يبقى ثابتاً عبر إعادة التشغيل
# CVISION_API_SECRET=

# [Required] Refresh token signing secret for CVision
# مفتاح توقيع رمز التحديث — مطلوب
# CVISION_REFRESH_SECRET=

# --- CVision Encryption (REQUIRED in production) ---
# تشفير CVision — مطلوب في الإنتاج

# [Required in production] 64-char hex string for encrypting PII at rest
# Used for sensitive fields: nationalId, bankIBAN, etc.
# Generate with: openssl rand -hex 32
# سلسلة hex مكونة من 64 حرفاً لتشفير البيانات الشخصية الحساسة كرقم الهوية وIBAN
# ENCRYPTION_KEY=

# --- CVision AI (Optional) ---
# الذكاء الاصطناعي لـ CVision — اختياري

# [Optional] OpenAI API key — for AI interview processing
# مفتاح OpenAI — لمعالجة المقابلات بالذكاء الاصطناعي
# OPENAI_API_KEY=

# [Optional] Anthropic API key — alternative AI provider for interview processing
# مفتاح Anthropic — بديل لمعالجة المقابلات بالذكاء الاصطناعي
# ANTHROPIC_API_KEY=

# --- CVision SMS (Optional) ---
# رسائل SMS لـ CVision — اختياري

# [Optional] Unifonic SMS gateway App SID
# معرف تطبيق Unifonic لبوابة الرسائل القصيرة
# UNIFONIC_APP_SID=

# [Optional] Twilio SMS gateway — account SID
# معرف حساب Twilio — اختياري (see also TWILIO_* in Integrations section)
# TWILIO_ACCOUNT_SID=

# [Optional] Twilio auth token
# رمز مصادقة Twilio — اختياري
# TWILIO_AUTH_TOKEN=

# ==============================================================================
# 🏛️ INTEGRATIONS — التكاملات
# ==============================================================================

# --- NPHIES (Saudi Insurance — نفيس) ---
# NPHIES uses FHIR R4 standard for Saudi health insurance transactions.
# تستخدم NPHIES معيار FHIR R4 لمعاملات التأمين الصحي السعودي.
#
# Required for eligibility checks, claims, and prior authorization:
# مطلوب للتحقق من الأهلية والمطالبات والموافقة المسبقة:
#
# [Required] NPHIES API base URL
# رابط API الأساسي لـ NPHIES
# NPHIES_BASE_URL=https://hsb.nphies.sa/
#
# [Required] Provider license ID (issued by CCHI)
# رقم ترخيص مقدم الخدمة — صادر من مجلس الضمان الصحي
# NPHIES_LICENSE_ID=
#
# [Required] Sender/facility ID
# معرف المرسل / المنشأة
# NPHIES_SENDER_ID=
#
# [Required] Provider organization ID
# معرف مؤسسة مقدم الخدمة
# NPHIES_PROVIDER_ID=
#
# [Required] OAuth2 client ID for NPHIES API
# معرف عميل OAuth2 لـ NPHIES
# NPHIES_CLIENT_ID=
#
# [Required] OAuth2 client secret for NPHIES API
# مفتاح عميل OAuth2 السري لـ NPHIES
# NPHIES_CLIENT_SECRET=
#
# [Optional] Enable sandbox/test mode (default: false)
# تفعيل وضع الاختبار — اختياري
# NPHIES_SANDBOX=0

# --- Nafis ---
# NAFIS_BASE_URL=https://api.nafis.sa
# NAFIS_API_KEY=
# NAFIS_FACILITY_ID=

# --- Absher ---
# ABSHER_BASE_URL=https://api.absher.sa
# ABSHER_CLIENT_ID=
# ABSHER_CLIENT_SECRET=
# ABSHER_SERVICE_ID=

# --- Twilio SMS ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# --- Thea Engine (Policy AI) ---
# THEA_ENGINE_URL=http://localhost:8000
# POLICY_ENGINE_URL=http://localhost:8000

# ==============================================================================
# 📂 STORAGE — التخزين
# ==============================================================================

# [Optional] Policies storage directory
# مجلد تخزين السياسات — اختياري
POLICIES_DIR=storage/policies

# ==============================================================================
# 🧪 TESTING — الاختبار
# ==============================================================================

# [Optional] Test secret for E2E tests
# TEST_SECRET=test-secret-change-in-production

# [Optional] Base URL for Playwright tests
# BASE_URL=http://localhost:3000

# ==============================================================================
# 🐛 DEBUG — التصحيح
# ==============================================================================

# [Optional] Debug auth middleware (logs extra info)
# DEBUG_AUTH=0

# [Optional] Debug tenant resolution
# DEBUG_TENANT=0

# ==============================================================================
# 📊 AUDIT — التدقيق
# ==============================================================================

# [Optional] Audit log retention in days
# AUDIT_LOG_RETENTION_DAYS=365

# ==============================================================================
# 🏥 CLINICAL — السريري
# ==============================================================================

# [Optional] Clinical infrastructure scheduling reference
# CLINICAL_INFRA_SCHEDULING_REF=
# NEXT_PUBLIC_CLINICAL_INFRA_SCHEDULING_REF=

# [Optional] Respiratory screening flags
# NEXT_PUBLIC_RESP_SCREEN_LOSS_SMELL=0
# NEXT_PUBLIC_RESP_SCREEN_OUTBREAK=0
# RESP_SCREEN_LOSS_SMELL=0
# RESP_SCREEN_OUTBREAK=0

# ==============================================================================
# ⏰ CRON — المهام المجدولة
# ==============================================================================

# [Optional] Cron endpoint secret
# CRON_SECRET=

# [Optional] Admin delete code for destructive operations
# ADMIN_DELETE_CODE=

# [Optional] Run consultation pricing migration on startup
# RUN_CONSULTATION_PRICING_MIGRATION=0

# [Optional] SAM tenant reset toggle
# SAM_ENABLE_TENANT_RESET=0

# ==============================================================================
# 💾 BACKUP — النسخ الاحتياطي
# ==============================================================================
#
# Supabase Automatic Backups:
# النسخ الاحتياطي التلقائي من Supabase:
#   - Pro plan: daily automatic backups (retained for 7 days)
#   - Enable Point-in-Time Recovery (PITR) from the Supabase Dashboard
#     Dashboard → Settings → Database → Backups → Enable PITR
#   - فعّل Point-in-Time Recovery من لوحة تحكم Supabase
#
# Manual Export:
# التصدير اليدوي:
#   - POST /api/admin/backup — exports critical data as gzip JSON
#   - CLI: npx tsx scripts/backup.ts --tenant=<id> --output=./backups/
#   - Schedule via cron: 0 2 * * * cd /app && npx tsx scripts/backup.ts --tenant=<id>

# ==============================================================================
# 🚩 PLATFORM FEATURE FLAGS — أعلام الميزات — Phase 0.2
# ==============================================================================
# All flags default to false (safe off). Set to "true" (exact string) to enable.
# جميع الأعلام معطّلة افتراضياً. اضبط على "true" لتفعيل الميزة.
#
# Phase 1 — Patient signup portal slug routing
THEA_FF_PORTAL_SLUG_ROUTING=false
# Phase 2 — Hospital-level entitlements & access control
THEA_FF_HOSPITAL_ENTITLEMENT=false
THEA_FF_TENANT_OWNER_ROLE=false
THEA_FF_HOSPITAL_SCOPED_GUARD=false
# Phase 3 — Core entity unification
THEA_FF_ORG_DEPT_UNIFIED=false
THEA_FF_ORG_UNIT_UNIFIED=false
THEA_FF_STAFF_IDENTITY_FK=false
THEA_FF_AUDIT_LOG_UNIFIED=false
# Phase 3.4 — AuditLog unification
THEA_FF_AUDITLOG_DUAL_WRITE=false
THEA_FF_AUDITLOG_UNIFIED_READ_SHADOW=false
# Phase 4 — Extension contract
THEA_FF_EXTENSION_CONTRACT=false
# Phase 4.2 — Event bus (LISTEN/NOTIFY + append-only events table)
# OFF (default): emit() is a no-op, no DB writes, no LISTEN loop started.
# ON: emit() persists events + pg_notify; startEventBus() opens a LISTEN connection.
# Apply migration 20260424000006_events_table before enabling.
# Call startEventBus() from your background worker, NOT from the web request path.
THEA_FF_EVENT_BUS_ENABLED=false
# Ack timeout for event handlers (milliseconds). Default 30000.
# THEA_EVENT_ACK_TIMEOUT_MS=30000
# Phase 4.3 — Cedar declarative authorization engine (shadow-eval only)
# OFF (default): Cedar is never loaded, zero overhead, zero behavioral change.
# THEA_FF_CEDAR_SHADOW_EVAL=true: Cedar evaluates in parallel with legacy auth, logs
#   any disagreements (outcome: match|disagreement|cedar_unavailable). Legacy decision
#   is ALWAYS returned — Cedar is NOT authoritative.
# THEA_FF_CEDAR_AUTHORITATIVE=true: Cedar becomes the decision source (do NOT flip until
#   shadow-eval shows zero disagreements over a monitoring period). NOT flipped in Phase 4.3.
THEA_FF_CEDAR_SHADOW_EVAL=false
THEA_FF_CEDAR_AUTHORITATIVE=false

# Phase 5.1 — Event sourcing projection layer. Apply migration
#   20260424000007_projection_tables before enabling.
THEA_FF_EVENT_PROJECTIONS_ENABLED=false

# Phase 5.2 — pgvector semantic embeddings (CoreDepartment pilot).
# Requires: OPENAI_API_KEY set + migration 20260424000008_pgvector_embeddings applied.
# When ON, embedCoreDepartment() stores text-embedding-3-large vectors (1536 dims).
# When OFF, all embedding operations are silent no-ops (EmbeddingsDisabled returned).
THEA_FF_EMBEDDINGS_ENABLED=false
# OPENAI_API_KEY is already declared above — ensure it is set when enabling this flag.

# Phase 6.1 — Arabic-native NLP stack.
# When ON, normalizeArabic(), matchMedicalPhrases(), expandSearchTerms() use the full
# Saudi-dialect medical lexicon. Zero external NLP service required.
THEA_FF_ARABIC_NLP_ENABLED=false

# Phase 6.2 — AI Agents framework.
# When OFF: agent registry empty, tool calls throw AgentsDisabled, /api/agents returns 404.
# When ON:  registerAgent/registerTool populate registries; runAgent creates AgentRun rows,
#   shadow-evaluates Cedar policy, emits events, and writes AgentToolCall rows.
# Requires: ANTHROPIC_API_KEY set + migration 20260424000009_ai_agents applied.
THEA_FF_AI_AGENTS_ENABLED=false

# [Required when FF_AI_AGENTS_ENABLED=true] Anthropic API key for LLM-driven agents.
# ANTHROPIC_API_KEY is loaded lazily — only read when an agent explicitly requests an LLM call.
# When flag is OFF this key is never accessed.
# ANTHROPIC_API_KEY=sk-ant-...
