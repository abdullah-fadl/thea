# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output
.next/
out/
build/
dist/

# Environment files (secrets — never bake into image)
.env
.env.local
.env.*.local
*.pem
*.key
credentials*.json
client_secret*.json

# Version control
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
*.zip

# Logs
logs/
*.log

# Tests
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
playwright.config.ts
playwright-report/

# Documentation
*.md
LICENSE
CHANGELOG

# Docker (avoid recursive copy)
Dockerfile
docker-compose.yml
.dockerignore

# Worktrees
worktrees/

# Storage (runtime data — mounted as volume)
storage/

# Python (policy-engine)
policy-engine/.venv/
policy-engine/venv/
policy-engine/env/
policy-engine/*.venv/
policy-engine/__pycache__/
policy-engine/**/__pycache__/
policy-engine/.pytest_cache/
policy-engine/**/*.pyc
policy-engine/**/*.pyo
policy-engine/**/*.pyd
policy-engine/.Python
policy-engine/**/*.so
policy-engine/.eggs/
policy-engine/dist/
policy-engine/build/
policy-engine/*.egg-info/
policy-engine/.installed.cfg
policy-engine/*.egg

# Keep Python source
!policy-engine/app/
!policy-engine/requirements.txt
!policy-engine/*.sh
!policy-engine/*.py
