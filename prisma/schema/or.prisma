  // Consents
  surgicalConsentSigned   Boolean   @default(false)
  anesthesiaConsentSigned Boolean   @default(false)
  bloodConsentSigned      Boolean   @default(false)
  // Lab & imaging
  labResultsReviewed      Boolean   @default(false)
  imagingReviewed         Boolean   @default(false)
  bloodProductsReady      Boolean   @default(false)
