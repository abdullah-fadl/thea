  tenantId             String    @db.Uuid
  caseId               String    @unique @db.Uuid
  surgeonUserId        String    @db.Uuid
  surgeonName          String?
  // Procedure details
  preOpDiagnosis       String?
  postOpDiagnosis      String?
  procedurePerformed   String?
  procedureCode        String?
  operationType        String? // ELECTIVE, EMERGENCY, URGENT
  laterality           String? // LEFT, RIGHT, BILATERAL, N_A
