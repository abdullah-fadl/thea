// =============================================================================
// OR Anesthesia Pre-Op Assessment (Pre-Operative Evaluation)
// =============================================================================

model OrAnesthesiaPreOp {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                 String    @db.Uuid
  caseId                   String    @unique @db.Uuid
  assessedByUserId         String    @db.Uuid
  assessedByName           String?
  assessedAt               DateTime  @db.Timestamptz
  // ASA classification
  asaClass                 String? // I, II, III, IV, V, VI
  asaEmergency             Boolean   @default(false)
  // Airway assessment
  mallampatiScore          String? // I, II, III, IV
  thyroMentalDistance      String? // NORMAL, REDUCED
  mouthOpening             String? // ADEQUATE, LIMITED
  neckMobility             String? // FULL, LIMITED, FIXED
  dentitionStatus          String? // NORMAL, MISSING, LOOSE, DENTURES, CROWNS
  beardPresent             Boolean   @default(false)
  predictedDifficultAirway Boolean   @default(false)
  airwayNotes              String?
  // Medical history
  cardiacHistory           Json? // {conditions:[], notes}
  respiratoryHistory       Json? // {conditions:[], notes}
  hepaticHistory           Json? // {conditions:[], notes}
  renalHistory             Json? // {conditions:[], notes}
  endocrineHistory         Json? // {conditions:[], notes}
  neurologicHistory        Json? // {conditions:[], notes}
  hematologicHistory       Json? // {conditions:[], notes}
  // Previous anesthesia
  previousAnesthesia       Boolean   @default(false)
  previousComplications    String?
  familyAnesthesiaHx       String? // malignant hyperthermia, etc.
  // Current medications
  currentMedications       Json      @default("[]") // [{medication, dose, frequency, lastDose}]
  herbals                  String?
  // NPO verification
  npoVerified              Boolean   @default(false)
  lastSolidsTime           DateTime? @db.Timestamptz
  lastClearLiquidsTime     DateTime? @db.Timestamptz
  // Planned anesthesia
  plannedAnesthesiaType    String? // GENERAL, REGIONAL, SPINAL, EPIDURAL, COMBINED, MAC, LOCAL
  plannedAirway            String? // ETT, LMA, MASK, AWAKE_FIBEROPTIC, TRACHEOSTOMY
  // Pre-medications
  preMedications           Json      @default("[]") // [{drug, dose, route, time}]
  // Risk assessment
  cardiacRiskIndex         String? // LOW, INTERMEDIATE, HIGH
  pulmonaryRiskScore       String?
  bleedingRisk             String? // LOW, MODERATE, HIGH
  ponvRisk                 String? // LOW, MODERATE, HIGH (Post-Op Nausea/Vomiting)
  // Informed consent
  risksExplained           Boolean   @default(false)
  consentObtained          Boolean   @default(false)
  // Overall status
  status                   String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, INCOMPLETE
  specialConsiderations    String?
  anesthesiaNotes          String?
  createdAt                DateTime  @default(now()) @db.Timestamptz
  updatedAt                DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, caseId])
  @@map("or_anesthesia_pre_ops")
}

