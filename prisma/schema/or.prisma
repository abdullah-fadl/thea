  ivSite                  String?
  ivGauge                 String?
  ivFluid                 String?
  // Skin assessment
  skinIntegrity           String? // INTACT, RASH, BRUISING, WOUND, PRESSURE_INJURY, OTHER
  skinNotes               String?
  // Mental status
