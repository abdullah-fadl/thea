// ── 3.18 OR Utilization Analytics ────────────────────────────────────────
model OrUtilizationSnapshot {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @db.Uuid
  snapshotDate       DateTime @db.Date
  roomName           String
  totalSlotMinutes   Int // available minutes in the day
  bookedMinutes      Int      @default(0)
  actualMinutes      Int      @default(0)
  casesScheduled     Int      @default(0)
  casesCompleted     Int      @default(0)
  casesCancelled     Int      @default(0)
  avgTurnoverMinutes Float? // average turnover between cases
  firstCaseOnTime    Boolean?
  delayMinutes       Int      @default(0)
  utilizationPct     Float? // actualMinutes / totalSlotMinutes * 100
  overtime           Int      @default(0) // minutes past scheduled end
  details            Json? // [{caseId, procedure, scheduledStart, actualStart, actualEnd, turnover}]
  createdAt          DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, snapshotDate, roomName])
  @@index([tenantId])
  @@index([tenantId, snapshotDate])
  @@map("or_utilization_snapshots")
}
