// =============================================================================
// Operating Room Domain — Cases, Events, Surgical Checklists
// =============================================================================

model OrCase {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @db.Uuid
  orderId              String    @db.Uuid
  encounterCoreId      String?   @db.Uuid
  episodeId            String?   @db.Uuid
  patientMasterId      String?   @db.Uuid
  procedureName        String?
  procedureCode        String?
  departmentKey        String?
  status               String    @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, CANCELLED
  // Scheduling fields
  scheduledDate        DateTime? @db.Date
  scheduledStartTime   DateTime? @db.Timestamptz
  scheduledEndTime     DateTime? @db.Timestamptz
  estimatedDurationMin Int?
  roomName             String? // Theater 1, Theater 2, etc.
  priority             String    @default("ELECTIVE") // EMERGENCY, URGENT, ELECTIVE
  caseType             String? // Elective, Emergency, Add-on
  surgeonName          String?
  anesthesiologistName String?
  asaClass             String? // ASA I, II, III, IV, V, VI
  createdAt            DateTime  @default(now()) @db.Timestamptz
  createdByUserId      String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, orderId])
  @@index([tenantId])
  @@index([tenantId, encounterCoreId])
  @@index([tenantId, scheduledDate])
  @@map("or_cases")
}

model OrCaseEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  caseId          String   @db.Uuid
  step            String // PRE_OP, TIME_OUT, INTRA_OP, POST_OP, RECOVERY
  data            Json? // Step-specific structured data
  createdAt       DateTime @default(now()) @db.Timestamptz
  createdByUserId String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, caseId])
  @@map("or_case_events")
}

// =============================================================================
// OR Time-Out — WHO Surgical Safety Checklist
// =============================================================================

model OrTimeOut {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @db.Uuid
  caseId             String   @unique @db.Uuid
  performedAt        DateTime @db.Timestamptz
  performedBy        String   @db.Uuid // userId (charge/circulating nurse)
  patientIdConfirmed Boolean  @default(false)
  procedureConfirmed Boolean  @default(false)
  siteConfirmed      Boolean  @default(false)
  consentConfirmed   Boolean  @default(false)
  antibioticGiven    Boolean  @default(false)
  imagingAvailable   Boolean  @default(false)
  equipmentReady     Boolean  @default(false)
  teamIntroduced     Boolean  @default(false)
  criticalConcerns   String?
  signatures         Json     @default("[]") // [{role, userId, name, timestamp}]
  createdAt          DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, caseId])
  @@map("or_time_outs")
}

// =============================================================================
