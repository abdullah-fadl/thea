// =============================================================================
// Referrals & Mortuary Domain
// =============================================================================

model Referral {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid
  patientName       String?
  patientMrn        String?
  patientMasterId   String?   @db.Uuid
  encounterCoreId   String?   @db.Uuid
  type              String? // internal, external
  fromProviderId    String?
  fromProviderName  String?
  fromSpecialtyCode String?
  fromSpecialtyName String?
  toProviderId      String?
  toProviderName    String?
  toSpecialtyCode   String?
  toSpecialtyName   String?
  toUserId          String?
  reason            String?
  urgency           String?
  diagnosisCodes    Json?
  clinicalNotes     String?
  externalFacility  String?
  transferBilling   Boolean   @default(false)
  status            String    @default("PENDING")
  acceptedBy        String?
  acceptedAt        DateTime? @db.Timestamptz
  rejectedBy        String?
  rejectedAt        DateTime? @db.Timestamptz
  rejectionReason   String?
  createdBy         String?
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("referrals")
}

model MortuaryCase {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  encounterCoreId String    @db.Uuid
  patientMasterId String?   @db.Uuid
  bodyTagNumber   String?
  status          String    @default("RECEIVED")
  location        Json?
  releaseDetails  Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz
  createdByUserId String?
  updatedAt       DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, encounterCoreId])
  @@index([tenantId, status])
  @@map("mortuary_cases")
}
