// =============================================================================
// ICU APACHE II Score — Acute Physiology and Chronic Health Evaluation
// =============================================================================

model IcuApacheScore {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String   @db.Uuid
  episodeId            String   @db.Uuid
  scoredAt             DateTime @db.Timestamptz
  scoredByUserId       String   @db.Uuid
  scoredByName         String?
  version              String   @default("II") // II, IV
  // Acute Physiology Score (worst values in first 24h)
  temperature          Float?
  meanArterialPressure Float?
  heartRate            Int?
  respiratoryRate      Int?
  oxygenation          Float? // PaO2 or A-aDO2
  fio2                 Float?
  arterialPh           Float?
  serumSodium          Float?
  serumPotassium       Float?
  serumCreatinine      Float?
  hematocrit           Float?
  whiteBloodCount      Float?
  glasgowComaScale     Int?
  // Individual component scores
  temperatureScore     Int?
  mapScore             Int?
  hrScore              Int?
  rrScore              Int?
  oxygenScore          Int?
  phScore              Int?
  sodiumScore          Int?
  potassiumScore       Int?
  creatinineScore      Int?
  hctScore             Int?
  wbcScore             Int?
  gcsScore             Int?
  // Age & chronic health
  agePoints            Int?
  chronicHealthPoints  Int?
  isEmergencySurgery   Boolean  @default(false)
  chronicConditions    Json? // [{condition}] e.g. liver, cardiovascular, renal, immunocompromised, respiratory
  // Total
  acutePhysiologyScore Int?
  totalScore           Int?
  predictedMortality   Float? // Percentage
  notes                String?
  createdAt            DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, episodeId])
  @@map("icu_apache_scores")
}

// =============================================================================
// ICU Sedation Assessment — RASS (Richmond Agitation-Sedation Scale) / SAS
// =============================================================================

model IcuSedationAssessment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @db.Uuid
  episodeId        String   @db.Uuid
  assessedAt       DateTime @db.Timestamptz
  assessedByUserId String   @db.Uuid
  assessedByName   String?
  scaleType        String   @default("RASS") // RASS, SAS
  // RASS Score (-5 to +4)
  rassScore        Int?
  rassLabel        String? // UNAROUSABLE, DEEP_SEDATION, MODERATE_SEDATION, LIGHT_SEDATION, DROWSY, ALERT_CALM, RESTLESS, AGITATED, VERY_AGITATED, COMBATIVE
  // SAS Score (1-7)
  sasScore         Int?
  sasLabel         String? // UNAROUSABLE, VERY_SEDATED, SEDATED, CALM, AGITATED, VERY_AGITATED, DANGEROUS
  // Target
  targetRass       Int?
  targetSas        Int?
  isOnTarget       Boolean?
  // Sedation details
  sedationDrugs    Json? // [{drug, dose, rate, unit}]
  painScore        Int? // 0-10 NRS or BPS
  painTool         String? // NRS, BPS, CPOT
  bpsScore         Int?
  cpotScore        Int?
  // Interventions
  interventions    Json? // [{action, detail}]
  notes            String?
  createdAt        DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, episodeId])
  @@index([tenantId, episodeId, assessedAt])
  @@map("icu_sedation_assessments")
}

// =============================================================================
// ICU Delirium Screening — CAM-ICU (Confusion Assessment Method for ICU)
// =============================================================================

model IcuDeliriumScreen {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @db.Uuid
  episodeId             String   @db.Uuid
  screenedAt            DateTime @db.Timestamptz
  screenedByUserId      String   @db.Uuid
  screenedByName        String?
  toolUsed              String   @default("CAM_ICU") // CAM_ICU, ICDSC
  // CAM-ICU Features
  feature1AcuteOnset    Boolean? // Acute onset or fluctuating course
  feature2Inattention   Boolean? // Inattention (ASE letters/pictures)
  aseLetterScore        Int? // Number of errors in ASE letters
  asePictureScore       Int? // Number of errors in ASE pictures
  feature3AlteredLOC    Boolean? // Altered level of consciousness (RASS != 0)
  currentRass           Int?
  feature4Disorganized  Boolean? // Disorganized thinking (yes/no questions + command)
  questionErrors        Int?
  commandFollowed       Boolean?
  // Result
  camIcuPositive        Boolean? // true = delirium present
  deliriumType          String? // HYPERACTIVE, HYPOACTIVE, MIXED
  // ICDSC (alternative tool, 0-8)
  icdscScore            Int?
  icdscItems            Json? // [{item, present}]
  // Risk factors
  riskFactors           Json? // [{factor}] e.g. age>65, cognitive impairment, surgery, infection, medications
  // Interventions
  nonPharmInterventions Json? // [{intervention}] e.g. reorientation, sleep hygiene, mobilization, sensory aids
  pharmInterventions    Json? // [{drug, dose, route}]
  notes                 String?
  createdAt             DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, episodeId])
  @@index([tenantId, episodeId, screenedAt])
  @@map("icu_delirium_screens")
}

// =============================================================================
// ICU Bundle Compliance — VAP, CLABSI, CAUTI Prevention Bundles
// =============================================================================

model IcuBundleCompliance {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @db.Uuid
  episodeId            String    @db.Uuid
  auditDate            DateTime  @db.Date
  auditedByUserId      String    @db.Uuid
  auditedByName        String?
  bundleType           String // VAP, CLABSI, CAUTI
  // VAP Bundle (Ventilator-Associated Pneumonia)
  vapHobElevated       Boolean? // Head of bed ≥30°
  vapDailyWean         Boolean? // Daily sedation vacation + spontaneous breathing trial
  vapOralCare          Boolean? // Oral care with chlorhexidine
  vapDvtProphylaxis    Boolean? // DVT prophylaxis
  vapPepticProphylaxis Boolean? // Peptic ulcer prophylaxis
  vapSubglotticSuction Boolean? // Subglottic suctioning if available
  vapCircuitNotChanged Boolean? // Vent circuit not routinely changed
  // CLABSI Bundle (Central Line-Associated Bloodstream Infection)
  clabsiHandHygiene    Boolean?
  clabsiMaxBarrier     Boolean? // Full barrier precautions during insertion
  clabsiChlorhexidine  Boolean? // Chlorhexidine skin antisepsis
  clabsiOptimalSite    Boolean? // Optimal catheter site selection (subclavian preferred)
  clabsiDailyReview    Boolean? // Daily review of line necessity
  clabsiDressingIntact Boolean? // Dressing clean, dry, intact
  clabsiLineDate       DateTime? @db.Date // Line insertion date
  clabsiLineDays       Int? // Line days
  // CAUTI Bundle (Catheter-Associated Urinary Tract Infection)
  cautiIndication      Boolean? // Appropriate indication documented
  cautiAsepticInsert   Boolean? // Aseptic insertion technique
  cautiSecured         Boolean? // Catheter properly secured
  cautiBagBelow        Boolean? // Drainage bag below bladder
  cautiDailyReview     Boolean? // Daily review of necessity
  cautiRemovalDate     DateTime? @db.Date // Planned removal date
  cautiCathDays        Int?
  // Compliance
  totalElements        Int?
  compliantElements    Int?
  compliancePercent    Float?
  deviationNotes       String?
  actionPlan           String?
  createdAt            DateTime  @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, episodeId])
  @@index([tenantId, bundleType])
  @@index([tenantId, auditDate])
  @@map("icu_bundle_compliance")
}

// =============================================================================
// ICU Code Blue Documentation — ACLS Flowsheet
// =============================================================================

model IcuCodeBlue {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  episodeId        String?   @db.Uuid
  patientMasterId  String?   @db.Uuid
  location         String? // Ward, ICU bed, etc.
  // Event
  codeCalledAt     DateTime  @db.Timestamptz
  codeCalledBy     String?
  teamArrivedAt    DateTime? @db.Timestamptz
  initialRhythm    String? // VF, VT, PEA, ASYSTOLE, BRADYCARDIA, TACHYCARDIA, ROSC
  // Timeline
  events           Json      @default("[]") // [{time, action, detail, performedBy}]
  // CPR
  cprStartedAt     DateTime? @db.Timestamptz
  cprEndedAt       DateTime? @db.Timestamptz
  totalCprMin      Int?
  // Defibrillation
  shocks           Json? // [{time, joules, rhythm_before, rhythm_after}]
  // Medications
  medications      Json? // [{time, drug, dose, route}]
  // Airway
  airwayManagement String? // BVM, ETT, LMA, CRICOTHYROTOMY
  intubatedAt      DateTime? @db.Timestamptz
  intubatedBy      String?
  // IV access
  ivAccess         Json? // [{type, site, gauge, time}]
  ioAccess         Boolean?  @default(false)
  ioSite           String?
  // Team
  teamLeader       String?
  cprProvider1     String?
  cprProvider2     String?
  airwayManager    String?
  medicationNurse  String?
  recorder         String?
  // Outcome
  outcome          String? // ROSC, DEATH, ONGOING
  roscAt           DateTime? @db.Timestamptz
  timeOfDeath      DateTime? @db.Timestamptz
  postRoscPlan     String?
  // Family
  familyNotified   Boolean   @default(false)
  familyNotifiedAt DateTime? @db.Timestamptz
  familyNotifiedBy String?
  // Debrief
  debriefCompleted Boolean   @default(false)
  debriefNotes     String?
  status           String    @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, episodeId])
  @@index([tenantId, codeCalledAt])
  @@map("icu_code_blues")
}

// =============================================================================
// 4.3 — Brain Death Protocol
// =============================================================================

model BrainDeathProtocol {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @db.Uuid
  episodeId          String    @db.Uuid
  patientId          String    @db.Uuid
  status             String    @default("PREREQUISITES") // PREREQUISITES, EXAM1, WAITING, EXAM2, CONFIRMATORY, DECLARED, ABORTED
  prerequisites      Json? // {normothermia, normotension, noCnsDepressants, noMetabolicDerangement} each: {checked, value, checkedByUserId, checkedAt}
  exam1              Json? // {pupilReflexAbsent, cornealReflexAbsent, oculocephalicAbsent, oculovestibularAbsent, gagReflexAbsent, coughReflexAbsent, noMotorResponse, apneaTestResult, examinerUserId, examAt}
  waitingPeriodHours Int?      @default(6)
  exam2              Json? // same structure as exam1
  confirmatoryTest   Json? // {testType: EEG/ANGIOGRAPHY/TCD, result, performedAt, performedByUserId}
  declaredAt         DateTime? @db.Timestamptz
  declaredByUserId   String?   @db.Uuid
  scotNotified       Boolean   @default(false)
  scotNotifiedAt     DateTime? @db.Timestamptz
  abortedReason      String?
  createdByUserId    String?   @db.Uuid
  createdAt          DateTime  @default(now()) @db.Timestamptz
  updatedAt          DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, episodeId])
  @@index([tenantId, status])
  @@map("brain_death_protocols")
}

// =============================================================================
// 4.4 — Organ Donation Workflow
// =============================================================================

model OrganDonation {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String    @db.Uuid
  brainDeathProtocolId   String    @db.Uuid
  patientId              String    @db.Uuid
  status                 String    @default("IDENTIFIED") // IDENTIFIED, SCOT_NOTIFIED, FAMILY_APPROACHED, CONSENTED, REFUSED, DONOR_MANAGEMENT, PROCUREMENT_SCHEDULED, COMPLETED, WITHDRAWN
  scotReferralAt         DateTime? @db.Timestamptz
  scotReferenceNumber    String?
  familyApproach         Json? // {approachedByUserId, approachedAt, familyMemberName, relationship, outcome, consentDocumentId}
  donorManagement        Json? // {hemodynamicOptimization, organViabilityLabs, activeIssues}
  organAllocation        Json? // array of {organ, status, recipientCenter}
  procurementOrCaseId    String?   @db.Uuid
  procurementScheduledAt DateTime? @db.Timestamptz
  notes                  String?
  createdByUserId        String?   @db.Uuid
  createdAt              DateTime  @default(now()) @db.Timestamptz
  updatedAt              DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("organ_donations")
}
