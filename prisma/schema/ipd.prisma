// =============================================================================
// IPD Domain — Episodes, Admissions, Beds, Vitals, Downtime Incidents
// =============================================================================

model IpdEpisode {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String    @db.Uuid
  encounterId           String    @db.Uuid
  encounterType         String?
  patient               Json? // {id, fullName}
  serviceUnit           String?
  admittingDoctorUserId String?
  bedClass              String?
  admissionNotes        String?
  status                String    @default("ACTIVE") // ACTIVE, DISCHARGE_READY, DISCHARGED
  source                Json? // {type, encounterId} or {type, handoffId}
  location              Json? // {ward, unit, room, bed}
  ownership             Json? // {attendingPhysicianUserId, primaryInpatientNurseUserId}
  reasonForAdmission    String?
  doctorSummary         String?
  nursingSummary        String?
  pendingTasks          Json?
  pendingResults        Json?
  riskFlags             Json?
  closedAt              DateTime? @db.Timestamptz
  createdAt             DateTime  @default(now()) @db.Timestamptz
  updatedAt             DateTime  @updatedAt @db.Timestamptz
  createdByUserId       String?
  updatedByUserId       String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, encounterId])
  @@index([tenantId, status])
  @@map("ipd_episodes")
}

model IpdAdmission {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  episodeId        String?   @db.Uuid
  encounterId      String?   @db.Uuid
  patientMasterId  String?   @db.Uuid
  bedId            String?   @db.Uuid
  patientId        String?
  patientName      String?
  admissionDate    DateTime? @db.Date
  admissionTime    String?
  doctorName       String?
  diagnosis        String?
  dischargeDate    DateTime? @db.Date
  assignedAt       DateTime? @db.Timestamptz
  assignedByUserId String?
  releasedAt       DateTime? @db.Timestamptz
  releasedByUserId String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, episodeId])
  @@index([tenantId, bedId])
  @@index([tenantId, isActive])
  @@map("ipd_admissions")
}

model IpdBed {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.Uuid
  bedLabel       String?
  label          String?
  ward           String?
  room           String?
  unit           String?
  departmentId   String?
  departmentName String?
  roomLabel      String?
  roomId         String?
  unitLabel      String?
