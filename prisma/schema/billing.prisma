model ServiceCatalog {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @db.Uuid
  code                String
  name                String
  nameAr              String?
  nameEn              String?
  nameLower           String?
  serviceType         String // VISIT, BED_DAY, NURSING, CONSULTATION
  description         String?
  chargeCatalogId     String?  @db.Uuid
  chargeCode          String?
  basePrice           Decimal  @db.Decimal(12, 2)
  pricing             Json? // {consultant, specialist, resident, default}
  rules               Json? // {followUpFree, followUpDays, requiresApproval}
  specialtyCode       String?
  applicability       String[] @default([])
  allowedForCash      Boolean  @default(true)
  allowedForInsurance Boolean  @default(true)
  status              String   @default("ACTIVE")
  departmentDomain    String?
  createdAt           DateTime @default(now()) @db.Timestamptz
  createdByUserId     String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@unique([tenantId, nameLower])
  @@index([tenantId, serviceType])
  @@index([tenantId, status])
  @@map("service_catalog")
}

