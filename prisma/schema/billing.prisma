// =============================================================================
// Billing Domain — Charges, Claims, Payments, Payers, Insurance, NPHIES
// =============================================================================

model BillingChargeCatalog {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @db.Uuid
  code                String // e.g., "VIS-0001", "LAB-0025"
  name                String
  nameAr              String?
  itemType            String // VISIT, LAB_TEST, IMAGING, PROCEDURE, MEDICATION, BED, SUPPLY, SERVICE
  departmentDomain    String? // ER, OPD, IPD, ICU, OR, LAB, RAD
  applicability       String[] @default([]) // departments where applicable
  flags               String[] @default([]) // e.g., ["CONTROLLED"]
  unitType            String // PER_VISIT, PER_TEST, PER_DAY, PER_PROCEDURE, PER_DOSE
  basePrice           Decimal  @db.Decimal(12, 2)
  allowedForCash      Boolean  @default(true)
  allowedForInsurance Boolean  @default(true)
  status              String   @default("ACTIVE") // ACTIVE, INACTIVE
  labSpecimen         String?
  labMethod           String?
  labPrepNotes        String?
  radModality         String?
  radBodySite         String?
  radContrastRequired Boolean?
  createdAt           DateTime @default(now()) @db.Timestamptz
  updatedAt           DateTime @updatedAt @db.Timestamptz
  createdByUserId     String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, itemType])
  @@map("charge_catalog")
}

model BillingChargeCatalogCounter {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @db.Uuid
  itemType String
  seq      Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, itemType])
  @@map("charge_catalog_counters")
}

model BillingChargeEvent {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  encounterCoreId String    @db.Uuid
  patientMasterId String?   @db.Uuid
  departmentKey   String? // REGISTRATION, EMERGENCY, OPD, LAB, RADIOLOGY, etc.
  source          Json // {type: 'ORDER'|'MANUAL', orderId?, orderItemId?}
  chargeCatalogId String    @db.Uuid
  code            String // denormalized from catalog
  name            String // denormalized from catalog
  unitType        String // denormalized from catalog
  quantity        Decimal   @db.Decimal(12, 4)
  unitPrice       Decimal   @db.Decimal(12, 2)
  totalPrice      Decimal   @db.Decimal(12, 2)
  payerType       String    @default("CASH") // CASH, INSURANCE, PENDING
  status          String    @default("ACTIVE") // ACTIVE, VOID
  reason          String? // void reason
  voidedAt        DateTime? @db.Timestamptz
  voidedBy        String?
  idempotencyKey  String?
  createdAt       DateTime  @default(now()) @db.Timestamptz
  createdBy       String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, encounterCoreId, status])
  @@index([tenantId, idempotencyKey])
  @@map("charge_events")
}

model BillingClaim {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  encounterCoreId String   @db.Uuid
  claimNumber     String
  patient         Json? // {id, name, identifiers?, dob?, gender?}
  provider        Json? // {department, encounterType}
  totals          Json // {grandTotalActive, counts: {active, voided, total}}
  breakdown       Json? // {byDepartment: [...], byOrderKind: [...]}
  lineItems       Json // array of line items
  payerContext    Json? // snapshot of payer context
  readiness       Json? // {encounterCoreId, ready, reasons[], metrics}
  createdAt       DateTime @default(now()) @db.Timestamptz
  createdByUserId String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, encounterCoreId])
  @@index([tenantId, createdAt])
  @@map("claims")
}

model BillingClaimEvent {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid
  claimId           String    @db.Uuid
  status            String // DRAFT, SUBMITTED, REJECTED, RESUBMITTED, PAID
  version           Int
  submittedAt       String? // ISO date string
  submittedByUserId String?
  rejectedAt        DateTime? @db.Timestamptz
  rejectedByUserId  String?
  rejectionReason   String?
  remittedAt        DateTime? @db.Timestamptz
  remittedByUserId  String?
  remittanceAmount  Decimal?  @db.Decimal(12, 2)
  createdAt         DateTime  @default(now()) @db.Timestamptz
  createdByUserId   String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, claimId, createdAt])
  @@map("claim_events")
}

