// =============================================================================
// CVision Attendance & Scheduling Domain
// =============================================================================

// ── Enums ────────────────────────────────────────────────────────────────────

enum CvisionAttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_LEAVE
  ON_LEAVE
  HOLIDAY
  REST_DAY
}

enum CvisionShiftType {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
  SPLIT
  FLEXIBLE
}

enum CvisionScheduleApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Shift Definitions ────────────────────────────────────────────────────────

model CvisionShift {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String           @db.Uuid
  code         String
  name         String
  nameAr       String?
  type         CvisionShiftType
  startTime    String // HH:mm
  endTime      String // HH:mm
  breakMinutes Int              @default(0)
  isOvernight  Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now()) @db.Timestamptz
  updatedAt    DateTime         @updatedAt @db.Timestamptz
  createdBy    String?
  updatedBy    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("cvision_shifts")
}

// ── Shift Templates (weekly patterns) ────────────────────────────────────────

model CvisionShiftTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  nameAr      String?
  description String?
  pattern     Json // array of daily shift assignments
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  createdBy   String?
  updatedBy   String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("cvision_shift_templates")
}

// ── Shift Assignments ────────────────────────────────────────────────────────

model CvisionShiftAssignment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  employeeId String
  shiftId    String
  date       DateTime @db.Date
  notes      String?
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz
  createdBy  String?
  updatedBy  String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, date])
  @@map("cvision_shift_assignments")
}

// ── Daily Attendance Records ─────────────────────────────────────────────────

model CvisionAttendance {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String                  @db.Uuid
  employeeId        String
  date              DateTime                @db.Date
  shiftId           String?
  checkIn           DateTime?               @db.Timestamptz
  checkOut          DateTime?               @db.Timestamptz
  status            CvisionAttendanceStatus @default(PRESENT)
  workingMinutes    Int?
  lateMinutes       Int                     @default(0)
  earlyLeaveMinutes Int                     @default(0)
  overtimeMinutes   Int                     @default(0)
  source            String? // biometric, manual, mobile
  notes             String?
  isApproved        Boolean                 @default(false)
  approvedBy        String?
  approvedAt        DateTime?               @db.Timestamptz
  createdAt         DateTime                @default(now()) @db.Timestamptz
  updatedAt         DateTime                @updatedAt @db.Timestamptz
  createdBy         String?
  updatedBy         String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([tenantId, employeeId, date])
  @@map("cvision_attendance")
}

// ── Attendance Corrections ───────────────────────────────────────────────────

model CvisionAttendanceCorrection {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  attendanceId   String
  employeeId     String
  correctionType String // check_in, check_out, status
  originalValue  String?
  correctedValue String
  reason         String
  status         String    @default("pending")
  approvedBy     String?
  approvedAt     DateTime? @db.Timestamptz
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz
  createdBy      String?
  updatedBy      String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, attendanceId])
  @@index([tenantId, status])
  @@map("cvision_attendance_corrections")
}

// ── Raw Biometric / Punch Data ───────────────────────────────────────────────

model CvisionBiometricLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  employeeId   String
  deviceId     String?
  punchTime    DateTime @db.Timestamptz
  direction    String? // IN, OUT
  rawData      Json?
  processed    Boolean  @default(false)
  attendanceId String?
  createdAt    DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, punchTime])
  @@index([tenantId, processed])
  @@map("cvision_biometric_logs")
}

// ── Work Schedule Entries ────────────────────────────────────────────────────

model CvisionScheduleEntry {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  employeeId   String
  date         DateTime @db.Date
  shiftId      String?
  scheduleType String // regular, overtime, on_call
  startTime    String?
  endTime      String?
  notes        String?
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
  createdBy    String?
  updatedBy    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, date])
  @@index([tenantId, employeeId, date])
  @@map("cvision_schedule_entries")
}

// ── Schedule Approval Workflow ───────────────────────────────────────────────

model CvisionScheduleApproval {
  id              String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String                        @db.Uuid
  departmentId    String
  weekStartDate   DateTime                      @db.Date
  weekEndDate     DateTime                      @db.Date
  status          CvisionScheduleApprovalStatus @default(PENDING)
  submittedBy     String
  submittedAt     DateTime                      @db.Timestamptz
  approvedBy      String?
  approvedAt      DateTime?                     @db.Timestamptz
  rejectionReason String?
  createdAt       DateTime                      @default(now()) @db.Timestamptz
  updatedAt       DateTime                      @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, status])
  @@index([tenantId, weekStartDate])
  @@map("cvision_schedule_approvals")
}

// ── Employee Shift Preferences ───────────────────────────────────────────────

model CvisionEmployeeShiftPreference {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String            @db.Uuid
  employeeId         String
  preferredShiftType CvisionShiftType?
  availableDays      Json? // array of day names
  restrictions       Json?
  notes              String?
  createdAt          DateTime          @default(now()) @db.Timestamptz
  updatedAt          DateTime          @updatedAt @db.Timestamptz
  createdBy          String?
  updatedBy          String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@map("cvision_employee_shift_preferences")
}

// ── Department Work Schedule Rules ───────────────────────────────────────────

model CvisionDepartmentWorkSchedule {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.Uuid
  departmentId   String
  workDays       Json // array of day names
  defaultShiftId String?
  overtimePolicy Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @updatedAt @db.Timestamptz
  createdBy      String?
  updatedBy      String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, departmentId])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("cvision_department_work_schedules")
}

// ── Geofence (mobile attendance boundaries) ──────────────────────────────────

model CvisionGeofence {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  latitude     Decimal
  longitude    Decimal
  radiusMeters Int
  isActive     Boolean  @default(true)
  branchId     String?
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
  createdBy    String?
  updatedBy    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("cvision_geofences")
}
