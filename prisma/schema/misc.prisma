model PxCase {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseNumber        Int       @unique @default(autoincrement())
  tenantId          String    @db.Uuid
  visitId           String?   @db.Uuid
  patientId         String?   @db.Uuid
  status            String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED, ESCALATED
  severity          String? // LOW, MEDIUM, HIGH, CRITICAL
  categoryKey       String? // billing, clinical, communication, facility, food, medication, staff, wait_time, other
  subjectName       String? // patient/complainant display name
  subjectMrn        String?
  contactPhone      String?
  contactEmail      String?
  assignedDeptKey   String?
  assigneeUserId    String?   @db.Uuid
  createdByUserId   String?   @db.Uuid
  satisfactionScore Int? // 1..5 (post-resolution)
  dueAt             DateTime? @db.Timestamptz
  escalationLevel   Int       @default(0)
  resolvedAt        DateTime? @db.Timestamptz
  resolutionMinutes Int?
  resolutionNotes   String?
  detailsEn         String?
  detailsAr         String?
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @updatedAt @db.Timestamptz

  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  comments PxComment[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, categoryKey])
  @@index([tenantId, assigneeUserId])
  @@index([tenantId, createdAt])
  @@map("px_cases")
}

// Timeline entries for a PxCase: comments, status changes, escalations, assignments.
model PxComment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  caseId       String   @db.Uuid
  authorUserId String?  @db.Uuid
  authorName   String?
  kind         String   @default("COMMENT") // COMMENT | STATUS_CHANGE | ESCALATION | ASSIGNMENT | RESOLUTION
  body         String
  metadata     Json?
  createdAt    DateTime @default(now()) @db.Timestamptz

  case PxCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([caseId, createdAt])
  @@map("px_comments")
}

// Visit-level patient experience signal: satisfaction, sentiment, complaint flag.
model PxVisitExperience {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid
  visitId           String?   @db.Uuid
  patientId         String?   @db.Uuid
  patientName       String?
  patientMrn        String?
  departmentKey     String?
  visitDate         DateTime? @db.Timestamptz
  satisfactionScore Int? // 1..5
  sentiment         String? // POSITIVE | NEUTRAL | NEGATIVE | CONCERN
  hasComplaint      Boolean   @default(false)
  feedbackText      String?
  recordedByUserId  String?   @db.Uuid
  createdAt         DateTime  @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, visitDate])
  @@index([tenantId, departmentKey])
  @@index([tenantId, sentiment])
  @@map("px_visit_experiences")
}

// Platform-level status checks (no tenantId needed)
model StatusCheck {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientName String
  timestamp  DateTime @default(now()) @db.Timestamptz

  @@map("status_checks")
}

