// =============================================================================
// Newborn / NICU Records
// =============================================================================

model NewbornRecord {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @db.Uuid
  motherPatientId      String    @db.Uuid
  laborRecordId        String?   @db.Uuid
  // Birth details
  dateOfBirth          DateTime  @db.Timestamptz
  timeOfBirth          DateTime? @db.Timestamptz
  gestationalAge       Int? // weeks
  gestationalAgeDays   Int? // additional days
  birthWeight          Decimal?  @db.Decimal(8, 2) // grams
  birthLength          Decimal?  @db.Decimal(8, 2) // cm
  headCircumference    Decimal?  @db.Decimal(8, 2) // cm
  gender               String? // MALE, FEMALE, AMBIGUOUS
  deliveryType         String? // SVD, CS, INSTRUMENTAL_VACUUM, INSTRUMENTAL_FORCEPS
  presentation         String? // CEPHALIC, BREECH, TRANSVERSE
  // APGAR scores
  apgar1Min            Int? // 0-10
  apgar5Min            Int? // 0-10
  apgar10Min           Int? // 0-10
  // Resuscitation
  resuscitationNeeded  Boolean   @default(false)
  resuscitationSteps   Json? // [{step, time}]
  // Vitals at birth
  heartRate            Int?
  respiratoryRate      Int?
  temperature          Decimal?  @db.Decimal(4, 1)
  oxygenSaturation     Int?
  // Newborn exam
  skinColor            String? // PINK, ACROCYANOSIS, CYANOTIC, JAUNDICED, PALE
  cry                  String? // STRONG, WEAK, ABSENT
  tone                 String? // GOOD, DECREASED, FLOPPY
  reflexes             String? // NORMAL, DECREASED, ABSENT
  anomalies            Json? // [{system, finding, details}]
  // Cord
  cordBloodGas         Json? // {arterialPH, arterialBE, venousPH, venousBE}
  cordClamped          Boolean   @default(false)
  cordClampTime        DateTime? @db.Timestamptz
  cordBloodBanked      Boolean   @default(false)
  // Vitamin K & Eye prophylaxis
  vitaminKGiven        Boolean   @default(false)
  eyeProphylaxis       Boolean   @default(false)
  // Feeding
  firstFeedTime        DateTime? @db.Timestamptz
  feedingType          String? // BREAST, FORMULA, MIXED, NPO
  skinToSkin           Boolean   @default(false)
  skinToSkinTime       DateTime? @db.Timestamptz
  // Identification
  bandApplied          Boolean   @default(false)
  footprintsTaken      Boolean   @default(false)
  // NICU
  nicuAdmission        Boolean   @default(false)
  nicuAdmissionReason  String?
  nicuAdmittedAt       DateTime? @db.Timestamptz
  // Status
  status               String    @default("ACTIVE") // ACTIVE, DISCHARGED, TRANSFERRED, DECEASED
  dischargedAt         DateTime? @db.Timestamptz
  attendingPhysician   String?
  attendingPhysicianId String?   @db.Uuid
  notes                String?
  createdAt            DateTime  @default(now()) @db.Timestamptz
  updatedAt            DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, motherPatientId])
  @@index([tenantId, status])
  @@map("newborn_records")
}

