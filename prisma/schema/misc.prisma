// =============================================================================
// Misc Domain — Org Nodes, Departments, Equipment, Nursing, Identity, Dental, OB/GYN, etc.
// =============================================================================

model OrgNode {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  type         String? // department, unit, floor, room, section, committee, custom
  name         String
  code         String?
  description  String?
  parentId     String?  @db.Uuid
  level        Int?
  path         String?
  departmentId String?
  isActive     Boolean  @default(true)
  metadata     Json?
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
  createdBy    String?
  updatedBy    String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, parentId])
  @@map("org_nodes")
}

model FloorDepartment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.Uuid
  floorId        String?
  departmentId   String?
  departmentName String?
  departmentCode String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("floor_departments")
}

model DepartmentEntry {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  encounterCoreId String    @db.Uuid
  patientId       String?   @db.Uuid
  departmentKey   String
  enteredAt       DateTime? @db.Timestamptz
  exitedAt        DateTime? @db.Timestamptz
  status          String    @default("IN") // IN, OUT
  createdByUserId String?
  createdAt       DateTime  @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, encounterCoreId])
  @@map("department_entries")
}

model NursingAssignment {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid
  nurseId           String?
  nurseName         String?
  employeeId        String?
  position          String?
  isTeamLeader      Boolean   @default(false)
  isChargeNurse     Boolean   @default(false)
  weekStartDate     DateTime? @db.Date
  weekEndDate       DateTime? @db.Date
  assignments       Json?
  totalWeeklyHours  Int?
  targetWeeklyHours Int?
  overtimeHours     Int?
  undertimeHours    Int?
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("nursing_assignments")
}

model NursingShiftMetric {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @db.Uuid
  department     String?
  shift          String? // DAY, EVENING, NIGHT
  date           DateTime @db.Date
  nursesOnDuty   Int      @default(0)
  patientCount   Int      @default(0)
  completedTasks Int      @default(0)
  pendingTasks   Int      @default(0)
  criticalAlerts Int      @default(0)
  avgResponseMin Float?
  createdAt      DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, date])
  @@map("nursing_shift_metrics")
}

model Group {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  type        String?
  members     Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  createdBy   String?

  tenant Tenant @relation("TenantMiscGroups", fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("groups")
}

