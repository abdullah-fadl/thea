// =============================================================================
// CVision Admin Domain — Requests, Notifications, Workflows, Policies,
// Letters, Audit, Org Design, Integrations, Surveys, and System Models
// =============================================================================

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum CvisionRequestType {
  LEAVE
  SALARY_CERTIFICATE
  EMPLOYMENT_LETTER
  EXPENSE_CLAIM
  COMPLAINT
  TRANSFER
  TRAINING
  EQUIPMENT
  PAYROLL_ISSUE
  OTHER
}

enum CvisionRequestStatus {
  OPEN
  IN_REVIEW
  APPROVED
  REJECTED
  ESCALATED
  CLOSED
}

enum CvisionRequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// -----------------------------------------------------------------------------
// Requests & Ticketing
// -----------------------------------------------------------------------------

model CvisionRequest {
  id                      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String                 @db.Uuid
  requestNumber           String
  type                    CvisionRequestType
  priority                CvisionRequestPriority @default(MEDIUM)
  title                   String
  description             String
  requesterEmployeeId     String
  targetManagerEmployeeId String?
  departmentId            String
  status                  CvisionRequestStatus   @default(OPEN)
  statusChangedAt         DateTime?              @db.Timestamptz
  statusReason            String?
  confidentiality         String                 @default("normal") // normal, confidential, anonymous
  assignedToUserId        String?
  assignedAt              DateTime?              @db.Timestamptz
  escalatedAt             DateTime?              @db.Timestamptz
  escalationReason        String?
  slaDueAt                DateTime?              @db.Timestamptz
  slaBreached             Boolean                @default(false)
  closedAt                DateTime?              @db.Timestamptz
  closedBy                String?
  resolution              String?
  resolvedAt              DateTime?              @db.Timestamptz
  attachments             Json?
  isArchived              Boolean                @default(false)
  metadata                Json?

  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  createdBy String?
  updatedBy String?
  deletedAt DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, requestNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, requesterEmployeeId])
  @@map("cvision_requests")
}

model CvisionRequestEvent {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String  @db.Uuid
  requestId   String
  actorUserId String
  actorRole   String?
  eventType   String // created, comment, status_change, escalated, assigned, attachment_added
  payload     Json

  createdAt DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, requestId])
  @@map("cvision_request_events")
}

