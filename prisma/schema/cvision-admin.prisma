  tenantId        String  @db.Uuid
  configId        String
  action          String
  status          String // success, failed
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  duration        Int? // milliseconds

  createdAt DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, configId])
  @@map("cvision_integration_logs")
}

// -----------------------------------------------------------------------------
// Retention
// -----------------------------------------------------------------------------

model CvisionRetentionScore {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  employeeId   String
  score        Decimal
  riskLevel    String // low, medium, high, critical
  factors      Json
  calculatedAt DateTime @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@map("cvision_retention_scores")
}

model CvisionRetentionAlert {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @db.Uuid
  employeeId String
  alertType  String
  message    String?
  isResolved Boolean   @default(false)
  resolvedBy String?
  resolvedAt DateTime? @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@map("cvision_retention_alerts")
}

// -----------------------------------------------------------------------------
// Custom Dashboards
// -----------------------------------------------------------------------------

model CvisionDashboard {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String  @db.Uuid
  name            String
  widgets         Json
  createdByUserId String
  isDefault       Boolean @default(false)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("cvision_dashboards")
}
