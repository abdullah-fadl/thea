  odor              String? // NONE, MILD, MODERATE, STRONG
  painScore         Int?
  treatment         Json? // {cleanser, primaryDressing, secondaryDressing, frequency, notes}
  photoAttachmentId String?
  healingTrajectory String? // IMPROVING, STATIC, DETERIORATING
  notes             String?
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, patientMasterId])
  @@map("wound_assessments")
}

