// =============================================================================
// Wound Care Charting
// =============================================================================

model WoundAssessment {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @db.Uuid
  patientMasterId   String   @db.Uuid
  episodeId         String?  @db.Uuid
  encounterId       String?  @db.Uuid
  assessedBy        String   @db.Uuid // userId
  assessmentDate    DateTime @db.Timestamptz
  woundType         String // SURGICAL, PRESSURE, DIABETIC, VASCULAR, TRAUMATIC, BURN, OTHER
  woundLocation     String
  stage             String? // Pressure: I, II, III, IV, UNSTAGEABLE, DTI
  length            Float? // cm
  width             Float? // cm
  depth             Float? // cm
  tunneling         Boolean  @default(false)
  undermining       Boolean  @default(false)
  woundBed          Json? // {granulationPct, sloughPct, escharPct, epithelialPct}
  exudate           Json? // {amount: NONE/SCANT/MODERATE/HEAVY, type: SEROUS/SANGUINEOUS/PURULENT}
