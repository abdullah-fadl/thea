  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@map("data_erasure_requests")
}

// =============================================================================
// 6.0 — PDPL Data Breach Notification
// =============================================================================

model DataBreachIncident {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid
  title             String
  description       String
  severity          String    @default("medium") // low | medium | high | critical
  status            String    @default("detected") // detected | investigating | contained | resolved | reported_to_authority
  detectedAt        DateTime  @default(now()) @db.Timestamptz
  detectedBy        String    // userId
  containedAt       DateTime? @db.Timestamptz
  resolvedAt        DateTime? @db.Timestamptz
  affectedRecords   Int       @default(0)
  affectedPatients  Int       @default(0)
  dataCategories    String[]  // e.g., ["demographics", "medical_records", "billing"]
  rootCause         String?
  remediation       String?
  notifiedAuthority Boolean   @default(false)
  authorityNotifiedAt DateTime? @db.Timestamptz
  notifiedPatients  Boolean   @default(false)
  patientsNotifiedAt DateTime? @db.Timestamptz
  timeline          Json?     // array of { date, action, actor, notes }
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, detectedAt])
  @@map("data_breach_incidents")
}

// =============================================================================
// Medication Administration Record (MAR)
// =============================================================================

model MedicationAdministration {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  encounterCoreId  String    @db.Uuid
  patientId        String    @db.Uuid
  medicationId     String?   @db.Uuid
  medicationName   String
  dose             String
  route            String    // PO, IV, IM, SC, etc.
  scheduledTime    DateTime  @db.Timestamptz
  administeredTime DateTime? @db.Timestamptz
  status           String    @default("SCHEDULED") // GIVEN, HELD, REFUSED, NOT_GIVEN, SCHEDULED
  holdReason       String?
  refusalReason    String?
  notes            String?
  nurseId          String?   @db.Uuid
  nurseName        String?
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  encounterCore EncounterCore @relation(fields: [encounterCoreId], references: [id])
  patient       PatientMaster @relation(fields: [patientId], references: [id])

  @@index([tenantId])
  @@index([tenantId, encounterCoreId])
  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@map("medication_administrations")
}

// =============================================================================
// Nursing Assessment (cross-module)
// =============================================================================

model NursingAssessment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  patientId       String    @db.Uuid
  encounterCoreId String    @db.Uuid
  type            String    // VITALS, PAIN, FALL_RISK, SKIN, NEUROLOGICAL, etc.
  vitalSigns      Json?     // { bp, hr, temp, rr, spo2, weight, height, bmi, painLevel, bloodGlucose }
  painLevel       Int?
  fallRisk        String?
  pressureUlcerRisk String?
  notes           String?
  assessedBy      String?   @db.Uuid
  assessedByName  String?
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @updatedAt @db.Timestamptz

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  encounterCore EncounterCore @relation(fields: [encounterCoreId], references: [id])
  patient       PatientMaster @relation(fields: [patientId], references: [id])

  @@index([tenantId])
  @@index([tenantId, encounterCoreId])
  @@index([tenantId, patientId])
  @@index([tenantId, type])
  @@map("nursing_assessments")
}
