// ── 3.19 TPN (Total Parenteral Nutrition) Orders ─────────────────────────
model TpnOrder {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @db.Uuid
  patientMasterId     String    @db.Uuid
  episodeId           String?   @db.Uuid
  orderedBy           String // userId
  orderDate           DateTime  @db.Timestamptz
  // Patient parameters
  weight              Float // kg
  height              Float? // cm
  bmi                 Float?
  // TPN Components
  totalVolume         Int // mL
  infusionRate        Float // mL/hr
  infusionHours       Int       @default(24) // hours
  dextrose            Json // {concentration,volume,calories}
  aminoAcids          Json // {concentration,volume,protein}
  lipids              Json? // {concentration,volume,calories}
  electrolytes        Json // [{name,amount,unit}] Na,K,Ca,Mg,Phos,Cl,Acetate
  vitamins            Json? // [{name,amount,unit}]
  traceElements       Json? // [{name,amount,unit}]
