// =============================================================================
// Clinical Domain — Visit Notes, Physical Exams, Death Records, Home Medications
// =============================================================================

model OpdVisitNote {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String  @db.Uuid
  encounterCoreId String? @db.Uuid
  opdEncounterId  String? @db.Uuid
  patientId       String? @db.Uuid

  // SOAP fields
  chiefComplaint          String?
  historyOfPresentIllness String?
  reviewOfSystems         Json? // { system: findings }
  pastMedicalHistory      String?
  familyHistory           String?
  socialHistory           String?

  // Exam
  physicalExam           String?
  physicalExamStructured Json? // Structured exam data

  // Assessment & Plan
  assessment String?
  plan       String?
  diagnoses  Json? // [{ code, description, type, ... }]

  // Vitals snapshot at time of note
  vitalsSnapshot Json? // { bp, hr, temp, rr, spo2, weight, height, ... }

  // Status
  status    String    @default("DRAFT") // DRAFT, SIGNED, AMENDED, VOID
  signedAt  DateTime? @db.Timestamptz
  signedBy  String?   @db.Uuid
  amendedAt DateTime? @db.Timestamptz
  amendedBy String?   @db.Uuid

  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  createdByUserId String?
  updatedByUserId String?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, encounterCoreId])
  @@index([tenantId, patientId])
  @@map("opd_visit_notes")
}

model PhysicalExam {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String  @db.Uuid
  encounterCoreId String? @db.Uuid
  patientId       String? @db.Uuid

  // Systems examination (structured JSON)
  systems Json? // { general, heent, neck, cardiovascular, respiratory, ... }
  summary String?
  notes   String?

  // Status
  status      String    @default("DRAFT") // DRAFT, FINAL
  finalizedAt DateTime? @db.Timestamptz
  finalizedBy String?   @db.Uuid

  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  createdByUserId String?
  updatedByUserId String?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, encounterCoreId])
  @@map("physical_exams")
}

model HomeMedication {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String  @db.Uuid
  patientId String? @db.Uuid

  // Medication details
  drugName  String?
  dose      String?
  unit      String?
  frequency String? // daily, bid, tid, qid, prn, weekly, monthly, etc.
  route     String? // oral, iv, im, sc, topical, inhaled, etc.
  strength  String?
  form      String? // tablet, capsule, syrup, injection, cream, etc.
  source    String? // patient_reported, pharmacy_system, referral_letter, etc.
  notes     String?

  // Status
  isActive   Boolean   @default(true)
  isVerified Boolean   @default(false)
  verifiedBy String?   @db.Uuid
  verifiedAt DateTime? @db.Timestamptz

  // Soft delete
  deletedAt DateTime? @db.Timestamptz

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  createdBy String?
  updatedBy String?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, patientId])
  @@map("home_medications")
}

model DeathDeclaration {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String  @db.Uuid
  patientId       String  @db.Uuid
  encounterCoreId String? @db.Uuid

  declaredAt   DateTime  @db.Timestamptz
  declaredBy   String?   @db.Uuid
  causeOfDeath String?
  placeOfDeath String?
  manner       String? // NATURAL, ACCIDENT, SUICIDE, HOMICIDE, UNDETERMINED
  notes        String?
  isFinalised  Boolean   @default(false)
  finalisedAt  DateTime? @db.Timestamptz
  finalisedBy  String?   @db.Uuid

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, patientId])
  @@map("death_declarations")
}

// =============================================================================
// Clinical Tasks, Notes, Handover, Consents, Events
// =============================================================================

model ClinicalTask {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  encounterCoreId  String?   @db.Uuid
  source           Json? // {system, sourceId}
  taskType         String?
  title            String?
  priority         String? // LOW, NORMAL, HIGH, URGENT
  status           String    @default("OPEN") // OPEN, CLAIMED, IN_PROGRESS, DONE, NOT_DONE, CANCELLED
  dueAt            DateTime? @db.Timestamptz
  assignedToUserId String?
  claimedAt        DateTime? @db.Timestamptz
  startedAt        DateTime? @db.Timestamptz
  completedAt      DateTime? @db.Timestamptz
  notDoneReason    String?
  cancelReason     String?
  idempotencyKey   String?   @unique
  createdByUserId  String?
  createdAt        DateTime  @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
