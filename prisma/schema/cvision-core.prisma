// =============================================================================
// CVision Core HR Domain — Departments, Units, Employees, Contracts, Positions
// =============================================================================

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum CvisionEmployeeStatus {
  ACTIVE
  PROBATION
  ON_ANNUAL_LEAVE
  ON_SICK_LEAVE
  ON_MATERNITY_LEAVE
  ON_UNPAID_LEAVE
  SUSPENDED
  SUSPENDED_WITHOUT_PAY
  NOTICE_PERIOD
  RESIGNED
  TERMINATED
  END_OF_CONTRACT
  RETIRED
  DECEASED
}

enum CvisionGender {
  MALE
  FEMALE
  OTHER
}

enum CvisionEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  INTERNSHIP
}

enum CvisionContractType {
  PERMANENT
  FIXED_TERM
  LOCUM
  PART_TIME
  INTERN
}

enum CvisionContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

// -----------------------------------------------------------------------------
// Models
// -----------------------------------------------------------------------------

model CvisionDepartment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  code        String
  name        String
  nameAr      String?
  description String?
  parentId    String?   @db.Uuid // self-referential department
  managerId   String?   @db.Uuid
  isActive    Boolean   @default(true)
  isArchived  Boolean   @default(false)
  sortOrder   Int?
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  createdBy   String?
  updatedBy   String?
  deletedAt   DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([parentId])
  @@map("cvision_departments")
}

model CvisionUnit {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  code             String
  name             String
  nameAr           String?
  description      String?
  departmentId     String?   @db.Uuid
  managerId        String?   @db.Uuid
  headNurseId      String?   @db.Uuid
  nursingManagerId String?   @db.Uuid
  minStaffDay      Int?
  minStaffNight    Int?
  minStaffEvening  Int?
  isActive         Boolean   @default(true)
  isArchived       Boolean   @default(false)
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  createdBy        String?
  updatedBy        String?
  deletedAt        DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, isActive])
  @@map("cvision_units")
}

model CvisionJobTitle {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  code             String
  name             String
  nameAr           String?
  description      String?
  departmentId     String?   @db.Uuid
  unitId           String?   @db.Uuid
  gradeId          String?   @db.Uuid
  isActive         Boolean   @default(true)
  isArchived       Boolean   @default(false)
  requirements     Json?
  responsibilities Json?
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  createdBy        String?
  updatedBy        String?
  deletedAt        DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, isActive])
  @@map("cvision_job_titles")
}

model CvisionGrade {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  code        String
  name        String
  nameAr      String?
  description String?
  level       Int
  minSalary   Decimal?  @db.Decimal(12, 2)
  maxSalary   Decimal?  @db.Decimal(12, 2)
  currency    String    @default("SAR")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  createdBy   String?
  updatedBy   String?
  deletedAt   DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("cvision_grades")
}

model CvisionBranch {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @db.Uuid
  code      String
  name      String
  nameAr    String?
  address   Json?
  city      String?
  country   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @db.Timestamptz
  updatedAt DateTime  @updatedAt @db.Timestamptz
  createdBy String?
  updatedBy String?
  deletedAt DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("cvision_branches")
}

model CvisionEmployee {
  id                String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String                @db.Uuid
  employeeNo        String
  nationalId        String?
  firstName         String
  lastName          String
  firstNameAr       String?
  lastNameAr        String?
  fullName          String?
  email             String?
  phone             String?
  dateOfBirth       DateTime?             @db.Date
  gender            CvisionGender?
  nationality       String?
  departmentId      String?               @db.Uuid
  unitId            String?               @db.Uuid
  jobTitleId        String?               @db.Uuid
  positionId        String?               @db.Uuid
  gradeId           String?               @db.Uuid
  managerEmployeeId String?               @db.Uuid // reporting manager
  branchId          String?               @db.Uuid
  workLocation      String?
  nursingRole       String?
  status            CvisionEmployeeStatus @default(ACTIVE)
  statusEffectiveAt DateTime?             @db.Timestamptz
  statusReason      String?
  hiredAt           DateTime?             @db.Timestamptz
  probationEndDate  DateTime?             @db.Date
  activatedAt       DateTime?             @db.Timestamptz
  resignedAt        DateTime?             @db.Timestamptz
  terminatedAt      DateTime?             @db.Timestamptz
  contractEndDate   DateTime?             @db.Date
  userId            String?               @db.Uuid // link to auth User
  isActive          Boolean               @default(true)
  isArchived        Boolean               @default(false)
  address           Json?
  emergencyContact  Json?
  metadata          Json?
  createdAt         DateTime              @default(now()) @db.Timestamptz
  updatedAt         DateTime              @updatedAt @db.Timestamptz
  createdBy         String?
  updatedBy         String?
  deletedAt         DateTime?             @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, departmentId])
  @@index([tenantId, unitId])
  @@index([tenantId, managerEmployeeId])
  @@index([tenantId, branchId])
  @@index([tenantId, isActive])
  @@index([userId])
  @@map("cvision_employees")
}

model CvisionEmployeeStatusHistory {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String                 @db.Uuid
  employeeId         String                 @db.Uuid
  fromStatus         CvisionEmployeeStatus?
  toStatus           CvisionEmployeeStatus
  reason             String?
  effectiveDate      DateTime               @db.Date
  lastWorkingDay     DateTime?              @db.Date
  endOfServiceAmount Decimal?               @db.Decimal(12, 2)
  notes              String?
  createdAt          DateTime               @default(now()) @db.Timestamptz
  updatedAt          DateTime               @updatedAt @db.Timestamptz
  createdBy          String?
  updatedBy          String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([employeeId])
  @@map("cvision_employee_status_history")
}

model CvisionContract {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String                @db.Uuid
  contractNo            String
  employeeId            String                @db.Uuid
  type                  CvisionContractType
  status                CvisionContractStatus @default(DRAFT)
  startDate             DateTime              @db.Date
  endDate               DateTime?             @db.Date
  basicSalary           Decimal?              @db.Decimal(12, 2)
  housingAllowance      Decimal?              @db.Decimal(12, 2)
  transportAllowance    Decimal?              @db.Decimal(12, 2)
  otherAllowances       Decimal?              @db.Decimal(12, 2)
  vacationDaysPerYear   Int?
  isActive              Boolean               @default(true)
  renewedFromContractId String?               @db.Uuid
  terminationDate       DateTime?             @db.Date
  terminationReason     String?
  createdAt             DateTime              @default(now()) @db.Timestamptz
  updatedAt             DateTime              @updatedAt @db.Timestamptz
  createdBy             String?
  updatedBy             String?
  deletedAt             DateTime?             @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contractNo])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([employeeId])
  @@map("cvision_contracts")
}

model CvisionBudgetedPosition {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid
  positionCode      String
  title             String
  departmentId      String?   @db.Uuid
  unitId            String?   @db.Uuid
  jobTitleId        String?   @db.Uuid
  gradeId           String?   @db.Uuid
  budgetedHeadcount Int       @default(1)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @updatedAt @db.Timestamptz
  createdBy         String?
  updatedBy         String?
  deletedAt         DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, positionCode])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, isActive])
  @@map("cvision_budgeted_positions")
}

model CvisionPositionSlot {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  positionId    String    @db.Uuid
  requisitionId String?   @db.Uuid
  employeeId    String?   @db.Uuid
  status        String    @default("VACANT") // VACANT, FILLED, FROZEN
  filledAt      DateTime? @db.Timestamptz
  frozenAt      DateTime? @db.Timestamptz
  notes         String?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz
  createdBy     String?
  updatedBy     String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, positionId])
  @@index([tenantId, status])
  @@index([employeeId])
  @@map("cvision_position_slots")
}

model CvisionEmployeeDocument {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  employeeId   String    @db.Uuid
  documentType String
  fileName     String
  storageKey   String
  mimeType     String?
  fileSize     Int?
  notes        String?
  expiryDate   DateTime? @db.Date
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
  createdBy    String?
  updatedBy    String?
  deletedAt    DateTime? @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([employeeId])
  @@index([tenantId, documentType])
  @@map("cvision_employee_documents")
}
