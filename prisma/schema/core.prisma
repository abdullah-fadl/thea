  email           String
  password        String
  firstName       String
  lastName        String
  displayName     String?
  role            String // Role key (e.g. admin, opd-nurse) - supports custom roles from role_definitions
  groupId         String?  @db.Uuid
  hospitalId      String?  @db.Uuid
  department      String?
