  // Use this accessor only when FF_STAFF_FK_ENFORCED is ON.
  cvisionEmployees CvisionEmployee[] @relation("CvisionEmployeeUser")

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([role])
  @@map("users")
}

