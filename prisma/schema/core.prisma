// =============================================================================
// Core Domain — Tenant, User, Session, Auth, Audit
// =============================================================================

model Tenant {
  id       String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String       @unique // Business key (e.g., 'thea-owner-dev', 'hmg-whh')
  name       String?
  dbName     String? // Legacy: MongoDB database name
  portalSlug String?      @unique // slug for the patient portal URL (e.g. 'hmg-whh')
  status     TenantStatus @default(ACTIVE)
  planType PlanType     @default(ENTERPRISE)

  // Platform entitlements
  entitlementSam     Boolean @default(false)
  entitlementHealth  Boolean @default(false)
  entitlementEdrac   Boolean @default(false)
  entitlementCvision Boolean @default(false)
  entitlementScm     Boolean @default(false)

  // Integration settings
  integrations Json? // { samHealth: { enabled, autoTriggerEnabled, ... } }

  // Subscription lifecycle
  subscriptionEndsAt     DateTime? @db.Timestamptz
  gracePeriodEndsAt      DateTime? @db.Timestamptz
  gracePeriodEnabled     Boolean   @default(false)
  maxUsers               Int       @default(100)
  subscriptionContractId String?

  // Organization profile
  orgTypeId          String?
  sector             String?
  countryCode        String?
  orgTypeChangeCount Int     @default(0)

  // Audit
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  createdBy String?
  updatedBy String?

  // Relations
  users                 User[]
