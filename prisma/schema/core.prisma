  expiryDate         DateTime? @db.Timestamptz
  status             String    @default("active") // active, expired, expiring_soon, revoked, pending_renewal, pending_verification
  verificationStatus String    @default("pending") // pending, verified, failed, waived
  verifiedBy         String?   @db.Uuid
  verifiedAt         DateTime? @db.Timestamptz
  documentUrl        String?
  category           String? // physician, nurse, pharmacist, technician, allied_health
  specialtyCode      String?
  notes              String?
  reminderSentAt     DateTime? @db.Timestamptz
  createdAt          DateTime  @default(now()) @db.Timestamptz
  updatedAt          DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@index([tenantId, credentialType])
  @@index([tenantId, expiryDate])
  @@map("staff_credentials")
}

model ClinicalPrivilege {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  userId           String    @db.Uuid
  staffName        String
  privilegeType    String // admitting, surgical, procedural, prescribing, sedation, laser, radiology_ordering, blood_transfusion, ventilator_management, central_line
  privilegeCode    String?
  department       String?
  status           String    @default("active") // active, suspended, revoked, temporary, probationary
  grantedBy        String    @db.Uuid
  grantedByName    String?
  grantedAt        DateTime  @default(now()) @db.Timestamptz
  expiresAt        DateTime? @db.Timestamptz
  conditions       String? // any conditions on the privilege
  supervisorId     String?   @db.Uuid // required supervisor for probationary
  caseLogRequired  Int? // minimum cases required
  caseLogCompleted Int       @default(0)
  lastReviewDate   DateTime? @db.Timestamptz
  nextReviewDate   DateTime? @db.Timestamptz
  notes            String?
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@index([tenantId, privilegeType])
  @@map("clinical_privileges")
}

model CredentialAlert {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  credentialId String?  @db.Uuid
  privilegeId  String?  @db.Uuid
  userId       String   @db.Uuid
  alertType    String // expiring_30d, expiring_60d, expiring_90d, expired, verification_needed, review_due
  message      String
  messageAr    String?
  isRead       Boolean  @default(false)
  isDismissed  Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, isRead])
  @@index([tenantId, alertType])
  @@map("credential_alerts")
}

// =============================================================================
// Integration API Keys — Per-tenant keys for machine-to-machine auth (HL7, FHIR, etc.)
// =============================================================================

model IntegrationApiKey {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  keyHash   String   @unique // SHA-256 hash of the raw API key
  type      String   // 'HL7', 'FHIR', 'LIS', etc.
  label     String?  // Human-readable name like "Lab System A"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([keyHash])
  @@index([tenantId, type])
  @@map("integration_api_keys")
}
