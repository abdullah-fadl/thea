  // Platform access
  platformAccessSam     Boolean?
  platformAccessHealth  Boolean?
  platformAccessEdrac   Boolean?
  platformAccessCvision Boolean?
  platformAccessScm     Boolean?

  // Two-factor authentication
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes Json? // [{ hash: string, used: boolean }]
  twoFactorEnabledAt   DateTime? @db.Timestamptz
  twoFactorPending     Json? // { secret, backupCodes, createdAt }

  // Password policy
  passwordChangedAt   DateTime? @db.Timestamptz // Last password change time
  passwordHistory     Json? // [{ hash: string, changedAt: string }] — last 5 passwords
  forcePasswordChange Boolean   @default(false) // Admin-set flag for forced change on next login

  // Password reset
  passwordResetToken   String? // SHA-256 hash of the reset token
  passwordResetExpires DateTime? @db.Timestamptz // Token expiry (1 hour from generation)

  // Audit
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  createdBy String?
  updatedBy String?

  // Relations
  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
