// ==========================================
// SAM — Policy Acknowledgment
// ==========================================

model PolicyAcknowledgment {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  policyId        String
  userId          String
  userName        String?
  userEmail       String?
  acknowledgedAt  DateTime  @default(now()) @db.Timestamptz
