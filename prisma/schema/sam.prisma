  updatedAt      DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@map("sam_reminders")
}

// ==========================================
// SAM — Evidence Attachments
// ==========================================

model SamEvidence {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  referenceId    String
  referenceType  String    // FINDING, COMPLIANCE, RISK, AUDIT, CORRECTIVE_ACTION
  title          String
  description    String?
  fileName       String?
  fileType       String?
  fileSize       Int?
  fileUrl        String?
