// =============================================================================
// SAM/Policy Domain — Policy Documents, Chunks, Practices, Risk Runs, Integrity
// =============================================================================

model PolicyDocument {
  id                            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                      String    @db.Uuid
  theaEngineId                  String?
  policyEngineId                String?
  title                         String
  originalFileName              String?
  filename                      String?
  fileType                      String?
  category                      String?
  entityType                    String?
  source                        String?
  scope                         String?
  departmentIds                 String[]  @default([])
  operationIds                  String[]  @default([])
  isActive                      Boolean   @default(true)
  deletedAt                     DateTime? @db.Timestamptz
  archivedAt                    DateTime? @db.Timestamptz
  status                        String    @default("draft")
  statusUpdatedAt               DateTime? @db.Timestamptz
  effectiveDate                 DateTime? @db.Date
  expiryDate                    DateTime? @db.Date
  version                       Int       @default(1)
  owners                        Json?
  reviewCycleMonths             Int?
  nextReviewDate                DateTime? @db.Date
  classification                Json?
  operationalMappingNeedsReview Boolean   @default(false)
  tagsStatus                    String?
  indexedAt                     DateTime? @db.Timestamptz
  progress                      Json?
  uploadedBy                    String?
  createdAt                     DateTime  @default(now()) @db.Timestamptz
  updatedAt                     DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("policy_documents")
}

model PolicyChunk {
  id           String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String                          @db.Uuid
  documentId   String                          @db.Uuid
  chunkIndex   Int
  content      String
  // Populated by `embedPolicyChunk()` when FF_EMBEDDINGS_ENABLED is ON.
  embeddingVec Unsupported("vector(1536)")?
  metadata     Json?
  createdAt    DateTime                        @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, documentId])
  @@map("policy_chunks")
}

model PolicyAlert {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  type      String?
  severity  String?
  message   String?
  details   Json?
  createdAt DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("policy_alerts")
}

model Practice {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  departmentId String?
  setting      String? // IPD, OPD, Corporate, Shared
  title        String
  description  String?
  frequency    String? // Rare, Occasional, Frequent, Daily
  ownerRole    String?
  status       String   @default("active")
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("practices")
}

model RiskRun {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @db.Uuid
  departmentId     String?
  setting          String?
  createdBy        String?
  inputPracticeIds String[] @default([])
  resultsJson      Json?
  createdAt        DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("risk_runs")
}

model Policy {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @db.Uuid
  title     String
  content   String?
  category  String?
  status    String   @default("draft")
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
  createdBy String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("policies")
}

model IntegrityFinding {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
