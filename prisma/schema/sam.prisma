// ==========================================
// SAM — Automated Reminders
// ==========================================

model SamReminder {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  type           String    // POLICY_REVIEW, AUDIT_OVERDUE, COMPLIANCE_DEADLINE, RISK_REVIEW
