// ==========================================
// SAM — Compliance Monitoring
// ==========================================

model ComplianceRequirement {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  title           String
  titleAr         String?
  description     String?
  descriptionAr   String?
  standardId      String?   @db.Uuid
  standardCode    String?
  category        String?
  priority        String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status          String    @default("NOT_MET") // NOT_MET, PARTIALLY_MET, MET, NOT_APPLICABLE
  dueDate         DateTime? @db.Date
  evidenceRequired Boolean  @default(false)
  assignedTo      String?
  departmentId    String?
  metadata        Json?
  createdBy       String?
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, standardId])
  @@map("sam_compliance_requirements")
}

model ComplianceViolation {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @db.Uuid
  requirementId     String?   @db.Uuid
  title             String
  titleAr           String?
  description       String?
  severity          String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status            String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  detectedAt        DateTime  @default(now()) @db.Timestamptz
  resolvedAt        DateTime? @db.Timestamptz
  resolvedBy        String?
  departmentId      String?
  assignedTo        String?
  correctiveActionId String?  @db.Uuid
  slaDeadline       DateTime? @db.Timestamptz
  metadata          Json?
  createdBy         String?
  createdAt         DateTime  @default(now()) @db.Timestamptz
  updatedAt         DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("sam_compliance_violations")
}

model CorrectiveAction {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  violationId   String?   @db.Uuid
  findingId     String?   @db.Uuid
  title         String
  titleAr       String?
  description   String?
  actionType    String    @default("CORRECTIVE") // CORRECTIVE, PREVENTIVE, IMPROVEMENT
  status        String    @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, VERIFIED, CLOSED
  priority      String    @default("MEDIUM")
  assignedTo    String?
  departmentId  String?
  dueDate       DateTime? @db.Date
  completedAt   DateTime? @db.Timestamptz
  completedBy   String?
  verifiedAt    DateTime? @db.Timestamptz
  verifiedBy    String?
  rootCause     String?
  actionTaken   String?
  effectiveness String?
  metadata      Json?
  createdBy     String?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("sam_corrective_actions")
}

// ==========================================
// SAM — Risk Assessment
// ==========================================

model RiskAssessment {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @db.Uuid
  title          String
  titleAr        String?
  description    String?
  riskCategory   String?
  likelihood     Int       @default(1) // 1-5
  impact         Int       @default(1) // 1-5
  riskScore      Int       @default(1) // likelihood * impact
  riskLevel      String    @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  status         String    @default("IDENTIFIED") // IDENTIFIED, ANALYZED, MITIGATING, MITIGATED, ACCEPTED, CLOSED
  departmentId   String?
  assignedTo     String?
  mitigationPlan String?
  residualRisk   Int?
  dueDate        DateTime? @db.Date
  reviewDate     DateTime? @db.Date
  metadata       Json?
  createdBy      String?
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, riskLevel])
  @@map("sam_risk_assessments")
}

model RiskMitigation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @db.Uuid
  riskId          String    @db.Uuid
  title           String
  titleAr         String?
  description     String?
  strategy        String    @default("MITIGATE") // AVOID, MITIGATE, TRANSFER, ACCEPT
  status          String    @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, VERIFIED
  assignedTo      String?
  dueDate         DateTime? @db.Date
  completedAt     DateTime? @db.Timestamptz
  completedBy     String?
  effectivenessScore Int?
  metadata        Json?
  createdBy       String?
  createdAt       DateTime  @default(now()) @db.Timestamptz
  updatedAt       DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, riskId])
  @@map("sam_risk_mitigations")
}

model RiskFollowUp {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  riskId      String    @db.Uuid
  note        String?
  status      String    @default("PENDING") // PENDING, COMPLETED
  scheduledAt DateTime  @db.Timestamptz
  completedAt DateTime? @db.Timestamptz
  completedBy String?
  metadata    Json?
  createdBy   String?
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, riskId])
  @@map("sam_risk_follow_ups")
}

// ==========================================
// SAM — Standards Management (CBAHI/JCI)
// ==========================================

model SamStandard {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  code          String
  title         String
  titleAr       String?
  description   String?
  descriptionAr String?
  framework     String   @default("CBAHI") // CBAHI, JCI, CUSTOM
  chapter       String?
  section       String?
  version       String?
  isActive      Boolean  @default(true)
  metadata      Json?
  createdBy     String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, framework, code])
  @@index([tenantId])
  @@index([tenantId, framework])
  @@map("sam_standards")
}

model StandardAssessment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  standardId    String    @db.Uuid
  status        String    @default("NOT_ASSESSED") // NOT_ASSESSED, NON_COMPLIANT, PARTIALLY_COMPLIANT, COMPLIANT
  score         Int?
  assessedBy    String?
  assessedAt    DateTime? @db.Timestamptz
  notes         String?
  departmentId  String?
  gapAnalysis   String?
  actionPlan    String?
  nextReviewDate DateTime? @db.Date
  metadata      Json?
  createdBy     String?
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, standardId])
  @@map("sam_standard_assessments")
}

model StandardEvidence {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  standardId   String    @db.Uuid
  assessmentId String?   @db.Uuid
  title        String
