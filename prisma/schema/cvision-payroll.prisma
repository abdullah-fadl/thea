// =============================================================================
// CVision Leave & Payroll Domain — Leave, Payroll, Loans, Compensation, Budgets
// =============================================================================

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum CvisionLeaveType {
  ANNUAL
  SICK
  UNPAID
  MATERNITY
  PATERNITY
  MARRIAGE
  BEREAVEMENT
  HAJJ
  COMPASSIONATE
  STUDY
  OTHER
}

enum CvisionLeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CvisionLoanStatus {
  PENDING
  ACTIVE
  PAID_OFF
  CANCELLED
}

enum CvisionPayrollRunStatus {
  DRAFT
  DRY_RUN
  APPROVED
  PAID
}

// -----------------------------------------------------------------------------
// Leave Models
// -----------------------------------------------------------------------------

model CvisionLeave {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String             @db.Uuid
  employeeId      String             @db.Uuid
  leaveType       CvisionLeaveType
  startDate       DateTime           @db.Date
  endDate         DateTime           @db.Date
  days            Decimal            @db.Decimal(5, 2)
  reason          String?
  status          CvisionLeaveStatus @default(PENDING)
  approvedBy      String?            @db.Uuid
  approvedAt      DateTime?          @db.Timestamptz
  rejectionReason String?
  attachments     Json?
  createdAt       DateTime           @default(now()) @db.Timestamptz
  updatedAt       DateTime           @updatedAt @db.Timestamptz
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?          @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([tenantId, employeeId, status])
  @@map("cvision_leaves")
}

model CvisionLeaveBalance {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String           @db.Uuid
  employeeId  String           @db.Uuid
  leaveType   CvisionLeaveType
  year        Int
  entitled    Decimal          @default(0) @db.Decimal(5, 2)
  used        Decimal          @default(0) @db.Decimal(5, 2)
  pending     Decimal          @default(0) @db.Decimal(5, 2)
  carriedOver Decimal          @default(0) @db.Decimal(5, 2)
  adjustment  Decimal          @default(0) @db.Decimal(5, 2)
  createdAt   DateTime         @default(now()) @db.Timestamptz
  updatedAt   DateTime         @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, leaveType, year])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@map("cvision_leave_balances")
}

// -----------------------------------------------------------------------------
// Payroll Models
// -----------------------------------------------------------------------------

model CvisionPayrollProfile {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  employeeId String   @db.Uuid
  baseSalary Decimal  @db.Decimal(12, 2)
  allowances Json // {"housing": 5000, "transport": 2000}
  deductions Json // {"gosi": ..., "tax": ...}
  bankIban   String?
  wpsId      String?
  isActive   Boolean  @default(true)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz
  createdBy  String?
  updatedBy  String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("cvision_payroll_profiles")
}

model CvisionPayrollRun {
  id         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String                  @db.Uuid
  period     String // "YYYY-MM"
  status     CvisionPayrollRunStatus @default(DRAFT)
  totals     Json? // {totalGross, totalNet, employeeCount}
  approvedAt DateTime?               @db.Timestamptz
  approvedBy String?                 @db.Uuid
  paidAt     DateTime?               @db.Timestamptz
  paidBy     String?                 @db.Uuid
  notes      String?
  isArchived Boolean                 @default(false)
  createdAt  DateTime                @default(now()) @db.Timestamptz
  updatedAt  DateTime                @updatedAt @db.Timestamptz
  createdBy  String?
  updatedBy  String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, period])
  @@map("cvision_payroll_runs")
}

model CvisionPayslip {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  runId      String   @db.Uuid
  employeeId String   @db.Uuid
  gross      Decimal  @db.Decimal(12, 2)
  net        Decimal  @db.Decimal(12, 2)
  breakdown  Json // {baseSalary, allowances, deductions, loanDeduction}
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz
  createdBy  String?
  updatedBy  String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, runId, employeeId])
  @@index([tenantId])
  @@index([tenantId, runId])
  @@index([tenantId, employeeId])
  @@map("cvision_payslips")
}

model CvisionPayrollExport {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  runId      String   @db.Uuid
  format     String // "WPS", "CSV", "BANK"
  fileName   String
  fileSize   Int?
  rowCount   Int
  checksum   String?
  exportedAt DateTime @db.Timestamptz
  exportedBy String   @db.Uuid
  metadata   Json?
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, runId])
  @@map("cvision_payroll_exports")
}

model CvisionPayrollDryRun {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  period        String // "YYYY-MM"
  results       Json
  employeeCount Int
  totalGross    Decimal? @db.Decimal(12, 2)
  totalNet      Decimal? @db.Decimal(12, 2)
  createdBy     String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, period])
  @@map("cvision_payroll_dry_runs")
}

// -----------------------------------------------------------------------------
// Loan Models
// -----------------------------------------------------------------------------

model CvisionLoan {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String            @db.Uuid
  employeeId       String            @db.Uuid
  loanNumber       String
  principal        Decimal           @db.Decimal(12, 2)
  monthlyDeduction Decimal           @db.Decimal(12, 2)
  remaining        Decimal           @db.Decimal(12, 2)
  status           CvisionLoanStatus @default(PENDING)
  startDate        DateTime          @db.Date
  endDate          DateTime?         @db.Date
  approvedBy       String?           @db.Uuid
  approvedAt       DateTime?         @db.Timestamptz
  notes            String?
  isArchived       Boolean           @default(false)
  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz
  createdBy        String?
  updatedBy        String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, loanNumber])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("cvision_loans")
}

model CvisionLoanPolicy {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @db.Uuid
  name              String
  maxAmount         Decimal? @db.Decimal(12, 2)
  maxMonths         Int?
  maxActiveLoans    Int      @default(1)
  eligibilityMonths Int      @default(6)
  interestRate      Decimal  @default(0) @db.Decimal(5, 4)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz
  createdBy         String?
  updatedBy         String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("cvision_loan_policies")
}

// -----------------------------------------------------------------------------
// Compensation & Salary Structure Models
// -----------------------------------------------------------------------------

model CvisionSalaryStructure {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  gradeId    String   @db.Uuid
  name       String
  components Json // array of salary components
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz
  createdBy  String?
  updatedBy  String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, gradeId])
  @@index([tenantId, isActive])
  @@map("cvision_salary_structures")
}

model CvisionEmployeeCompensation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  employeeId    String   @db.Uuid
  effectiveDate DateTime @db.Date
  basicSalary   Decimal  @db.Decimal(12, 2)
  allowances    Json // {housing, transport, ...}
  benefits      Json?
  notes         String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz
  createdBy     String?
  updatedBy     String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, effectiveDate])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@map("cvision_employee_compensations")
}

// -----------------------------------------------------------------------------
// Accounting / GL Models
// -----------------------------------------------------------------------------

model CvisionJournalEntry {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  runId       String?   @db.Uuid
  entryDate   DateTime  @db.Date
  description String?
  entries     Json // array of debit/credit items
  status      String    @default("draft")
  postedAt    DateTime? @db.Timestamptz
  postedBy    String?   @db.Uuid
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz
  createdBy   String?
  updatedBy   String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, runId])
  @@index([tenantId, status])
  @@index([tenantId, entryDate])
  @@map("cvision_journal_entries")
}

model CvisionGlMapping {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  componentType String // "salary", "housing", "gosi_employee", etc.
  glAccountCode String
  glAccountName String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz
  createdBy     String?
  updatedBy     String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, componentType])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("cvision_gl_mappings")
}

// -----------------------------------------------------------------------------
// Budget Models
// -----------------------------------------------------------------------------

model CvisionDepartmentBudget {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  departmentId String   @db.Uuid
  fiscalYear   Int
  totalBudget  Decimal  @db.Decimal(14, 2)
  utilized     Decimal  @default(0) @db.Decimal(14, 2)
  remaining    Decimal  @default(0) @db.Decimal(14, 2)
  notes        String?
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
  createdBy    String?
  updatedBy    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, departmentId, fiscalYear])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, fiscalYear])
  @@map("cvision_department_budgets")
}

model CvisionHeadcountBudget {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  departmentId  String   @db.Uuid
  fiscalYear    Int
  budgetedCount Int
  currentCount  Int      @default(0)
  frozen        Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz
  createdBy     String?
  updatedBy     String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, departmentId, fiscalYear])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, fiscalYear])
  @@map("cvision_headcount_budgets")
}
