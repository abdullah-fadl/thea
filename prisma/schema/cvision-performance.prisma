// =============================================================================
// CVision Performance, Training, Lifecycle & Disciplinary Domain
// =============================================================================

// ── Performance Reviews ─────────────────────────────────────────────────────

model CvisionPerformanceReview {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @db.Uuid
  employeeId          String
  reviewCycleId       String?
  reviewerEmployeeId  String?
  period              String
  overallScore        Decimal?
  ratings             Json // categories and scores
  strengths           String?
  areasForImprovement String?
  goals               Json?
  status              String    @default("draft") // draft, in_progress, completed, acknowledged
  acknowledgedAt      DateTime? @db.Timestamptz
  acknowledgedBy      String?
  createdAt           DateTime  @default(now()) @db.Timestamptz
  updatedAt           DateTime  @updatedAt @db.Timestamptz
  createdBy           String?
  updatedBy           String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, reviewCycleId])
  @@index([tenantId, status])
  @@map("cvision_performance_reviews")
}

// ── Review Cycles ───────────────────────────────────────────────────────────

model CvisionReviewCycle {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @db.Uuid
  name        String
  description String?
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  status      String   @default("draft") // draft, active, closed
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz
  createdBy   String?
  updatedBy   String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, status])
  @@map("cvision_review_cycles")
}

// ── OKRs (Objectives & Key Results) ─────────────────────────────────────────

model CvisionOkr {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  employeeId   String?
  departmentId String?
  title        String
  description  String?
  keyResults   Json // array of key results
  progress     Decimal  @default(0)
  period       String
  status       String   @default("active")
  parentOkrId  String?
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
  createdBy    String?
  updatedBy    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, departmentId])
  @@index([tenantId, status])
  @@index([tenantId, period])
  @@map("cvision_okrs")
}

// ── KPI Definitions ─────────────────────────────────────────────────────────

model CvisionKpi {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @db.Uuid
  name         String
  description  String?
  category     String?
  target       Decimal?
  actual       Decimal?
  unit         String?
  frequency    String? // daily, weekly, monthly, quarterly
  departmentId String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz
  createdBy    String?
  updatedBy    String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, category])
  @@index([tenantId, departmentId])
  @@map("cvision_kpis")
}

// ── Disciplinary Actions ────────────────────────────────────────────────────

model CvisionDisciplinary {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  employeeId       String
  type             String // verbal_warning, written_warning, final_warning, suspension, termination
  reason           String
  description      String?
  issuedDate       DateTime  @db.Date
  expiryDate       DateTime? @db.Date
  issuedBy         String
  witnessedBy      String?
  employeeResponse String?
  status           String    @default("active") // active, appealed, resolved, expired
  attachments      Json?
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  createdBy        String?
  updatedBy        String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, type])
  @@index([tenantId, status])
  @@map("cvision_disciplinary_actions")
}

// ── Promotions ──────────────────────────────────────────────────────────────

model CvisionPromotion {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  employeeId       String
  fromJobTitleId   String?
  toJobTitleId     String?
  fromGradeId      String?
  toGradeId        String?
  fromDepartmentId String?
  toDepartmentId   String?
  effectiveDate    DateTime  @db.Date
  salaryChange     Json?
  reason           String?
  status           String    @default("pending") // pending, approved, rejected, completed
  approvedBy       String?
  approvedAt       DateTime? @db.Timestamptz
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  createdBy        String?
  updatedBy        String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("cvision_promotions")
}

// ── Training Courses ────────────────────────────────────────────────────────

model CvisionTrainingCourse {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  name            String
  nameAr          String?
  description     String?
  category        String?
  provider        String?
  duration        Int? // hours
  cost            Decimal?
  currency        String   @default("SAR")
  isExternal      Boolean  @default(false)
  isMandatory     Boolean  @default(false)
  maxParticipants Int?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz
  createdBy       String?
  updatedBy       String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, category])
  @@map("cvision_training_courses")
}

// ── Training Enrollments ────────────────────────────────────────────────────

model CvisionTrainingEnrollment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @db.Uuid
  courseId      String
  employeeId    String
  scheduledDate DateTime? @db.Date
  completedDate DateTime? @db.Date
