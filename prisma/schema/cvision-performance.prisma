// ── Employee Profile Sections ───────────────────────────────────────────────

model CvisionEmployeeProfileSection {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @db.Uuid
  employeeId    String
  sectionKey    String // PERSONAL, EMPLOYMENT, FINANCIAL, CONTRACT
  schemaVersion Int      @default(1)
  data          Json
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz
  createdBy     String?
  updatedBy     String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, sectionKey])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@map("cvision_employee_profile_sections")
}

// ── Employee Profile Section History ────────────────────────────────────────

model CvisionEmployeeProfileSectionHistory {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  employeeId      String
  sectionKey      String
  schemaVersion   Int
  prevData        Json
  nextData        Json
  changedByUserId String
  changeReason    String?
  createdAt       DateTime @default(now()) @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "cv_profile_hist_tenant_idx")
  @@index([tenantId, employeeId], map: "cv_profile_hist_tenant_emp_idx")
  @@index([tenantId, employeeId, sectionKey], map: "cv_profile_hist_tenant_emp_sec_idx")
  @@map("cvision_employee_profile_section_history")
}

// ── Profile Section Schema Definitions ──────────────────────────────────────

model CvisionProfileSectionSchema {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String   @db.Uuid
  sectionKey      String
  version         Int
  schema          Json // field definitions
  isActive        Boolean  @default(true)
  createdByUserId String
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sectionKey, version])
  @@index([tenantId])
  @@index([tenantId, sectionKey])
  @@index([tenantId, isActive])
  @@map("cvision_profile_section_schemas")
}
