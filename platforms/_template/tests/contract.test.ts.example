  // -------------------------------------------------------------------------
  // Contract 2: Platform code must not write directly to core tables
  // -------------------------------------------------------------------------
  describe('Contract 2 — No direct core writes from platform lib', () => {
    it('lib/my-platform does not call prisma.patient.create/update/delete', () => {
      // Static analysis: grep the platform lib for forbidden calls.
      // This is a lightweight guard; CI should also run a stricter lint rule.
      const { execSync } = require('child_process');
      const forbidden = [
        'prisma.patient.create',
        'prisma.patient.update',
        'prisma.patient.delete',
        'prisma.encounter.create',
        'prisma.encounter.update',
        'prisma.encounter.delete',
        // add all core tables here
      ];

      for (const pattern of forbidden) {
        let found = '';
        try {
          found = execSync(`grep -r "${pattern}" lib/my-platform/ 2>/dev/null || true`).toString();
        } catch {
          found = '';
        }
        expect(found.trim()).toBe('');
      }
    });
  });

