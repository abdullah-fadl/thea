// ---------------------------------------------------------------------------
// Events this platform EMITS (for other modules to consume)
//
// These declarations serve as the authoritative source for Phase 4.2's
// event schema registry.  Each event must declare:
//   - type: namespaced string (my_platform.<entity>.<verb>)
//   - schemaVersion: integer, starts at 1
//   - payload shape (TypeScript interface below)
// ---------------------------------------------------------------------------

export interface MyPlatformOrderCreatedPayload {
  id: string;        // UUID of the new MyPlatform_OrderExtension row
  coreId: string;    // UUID of the core entity being extended
  tenantId: string;
  platformRefCode?: string;
}

export interface MyPlatformOrderApprovedPayload {
  id: string;
  coreId: string;
  tenantId: string;
  approvedBy: string;  // User UUID
  approvedAt: string;  // ISO 8601
}

